# ─────────────────────────────────────────────────────────────────────────────
# Attendance SaaS — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (required)
DATABASE_URL=postgresql://attendance:replace-with-a-strong-database-password@localhost:5432/attendance
POSTGRES_USER=attendance
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=attendance

# Redis (required for job queues, caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=replace-with-a-strong-redis-password

# JWT (required — change this!)
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_ACCESS_EXPIRY=2h
JWT_REFRESH_EXPIRY=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:80
WEB_APP_URL=http://localhost:5173

# Platform admin (first-time seed)
# Use real values only in your local/production .env. Never commit passwords.
PLATFORM_ADMIN_EMAIL=platform-admin@example.com
PLATFORM_ADMIN_PASSWORD=replace-with-a-strong-random-password

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=replace-with-smtp-app-password
SMTP_FROM=notifications@example.com
NOTIFY_EMAIL=admin@example.com

# Legacy migration (optional — run: npm run migrate:sqlite)
# LEGACY_DB_PATH=./data/attendance.db
# LEGACY_ORG_NAME=Archisys Innovations
# LEGACY_ORG_SLUG=archisys
