# ─────────────────────────────────────────────────────────────────────────────
# Attendance SaaS — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (required)
DATABASE_URL=postgresql://attendance:attendance_pass@localhost:5432/attendance

# Redis (required for job queues, caching)
REDIS_URL=redis://localhost:6379

# JWT (required — change this!)
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_ACCESS_EXPIRY=2h
JWT_REFRESH_EXPIRY=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:80

# Platform admin (first-time seed)
PLATFORM_ADMIN_EMAIL=admin@attendance.app
PLATFORM_ADMIN_PASSWORD=Admin@123!

# Email (SMTP)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=info@archisysinnovation.com
SMTP_PASS=K@thmandu&123
SMTP_FROM=info@archisysinnovation.com
NOTIFY_EMAIL=info@archisysinnovation.com

# Legacy migration (optional — run: npm run migrate:sqlite)
# LEGACY_DB_PATH=./data/attendance.db
# LEGACY_ORG_NAME=Archisys Innovations
# LEGACY_ORG_SLUG=archisys
