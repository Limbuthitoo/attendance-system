// ─────────────────────────────────────────────────────────────────────────────
// TRAINING — Courses, Sessions, Enrollments, Certifications
// ─────────────────────────────────────────────────────────────────────────────

model TrainingCourse {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  name             String
  category         String   @default("general")
  description      String?  @db.Text
  duration         String?
  isExternal       Boolean  @default(false) @map("is_external")
  provider         String?
  isMandatory      Boolean  @default(false) @map("is_mandatory")
  applicableDepts  String[] @default([]) @map("applicable_depts")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions         TrainingSession[]

  @@unique([orgId, name])
  @@map("training_courses")
  @@schema("hrm")
}

model TrainingSession {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  courseId          String   @map("course_id") @db.Uuid
  title            String
  trainerId        String?  @map("trainer_id") @db.Uuid
  startDate        DateTime @map("start_date")
  endDate          DateTime @map("end_date")
  location         String?
  maxParticipants  Int?     @map("max_participants")
  status           TrainingSessionStatus @default(SCHEDULED)
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  course           TrainingCourse       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  trainer          Employee?            @relation("session_trainer", fields: [trainerId], references: [id])
  enrollments      TrainingEnrollment[]

  @@index([orgId, startDate])
  @@map("training_sessions")
  @@schema("hrm")
}

enum TrainingSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  @@schema("hrm")
}

model TrainingEnrollment {
  id               String   @id @default(uuid()) @db.Uuid
  sessionId        String   @map("session_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  status           EnrollmentStatus @default(ENROLLED)
  completedAt      DateTime? @map("completed_at")
  score            Decimal?  @db.Decimal(5,2)
  feedback         String?   @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  session          TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee         Employee        @relation("enrollment_employee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([sessionId, employeeId])
  @@map("training_enrollments")
  @@schema("hrm")
}

enum EnrollmentStatus {
  ENROLLED
  ATTENDED
  COMPLETED
  FAILED
  CANCELLED
  NO_SHOW
  @@schema("hrm")
}

model Certification {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  name             String
  issuingAuthority String   @map("issuing_authority")
  issueDate        DateTime @map("issue_date") @db.Date
  expiryDate       DateTime? @map("expiry_date") @db.Date
  credentialId     String?  @map("credential_id")
  documentUrl      String?  @map("document_url")
  status           CertStatus @default(ACTIVE)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee         Employee     @relation("cert_employee", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId, employeeId])
  @@index([expiryDate])
  @@map("certifications")
  @@schema("hrm")
}

enum CertStatus {
  ACTIVE
  EXPIRED
  REVOKED
  @@schema("hrm")
}

// ─────────────────────────────────────────────────────────────────────────────
// ESS — Document Requests, Expense Claims, Assets
// ─────────────────────────────────────────────────────────────────────────────

model DocumentRequest {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  type             String
  purpose          String?
  status           DocRequestStatus @default(PENDING)
  processedBy      String?  @map("processed_by") @db.Uuid
  processedAt      DateTime? @map("processed_at")
  documentUrl      String?  @map("document_url")
  remarks          String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee         Employee     @relation("doc_requester", fields: [employeeId], references: [id], onDelete: Cascade)
  processor        Employee?    @relation("doc_processor", fields: [processedBy], references: [id])

  @@index([orgId, employeeId])
  @@index([orgId, status])
  @@map("document_requests")
  @@schema("hrm")
}

enum DocRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  @@schema("hrm")
}

model ExpenseClaim {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  category         String
  description      String
  amount           Decimal  @db.Decimal(12,2)
  receiptUrl       String?  @map("receipt_url")
  expenseDate      DateTime @map("expense_date") @db.Date
  status           ExpenseStatus @default(PENDING)
  approvedBy       String?  @map("approved_by") @db.Uuid
  approvedAt       DateTime? @map("approved_at")
  paidAt           DateTime? @map("paid_at")
  rejectionReason  String?  @map("rejection_reason")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee         Employee     @relation("expense_claimant", fields: [employeeId], references: [id], onDelete: Cascade)
  approver         Employee?    @relation("expense_approver", fields: [approvedBy], references: [id])

  @@index([orgId, employeeId])
  @@index([orgId, status])
  @@map("expense_claims")
  @@schema("hrm")
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  @@schema("hrm")
}

model Asset {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  name             String
  category         String
  assetTag         String?  @map("asset_tag")
  serialNumber     String?  @map("serial_number")
  purchaseDate     DateTime? @map("purchase_date") @db.Date
  purchaseCost     Decimal? @map("purchase_cost") @db.Decimal(12,2)
  condition        String   @default("good")
  status           AssetStatus @default(AVAILABLE)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignments      AssetAssignment[]

  @@index([orgId, status])
  @@map("assets")
  @@schema("hrm")
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
  DISPOSED
  LOST
  @@schema("hrm")
}

model AssetAssignment {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  assetId          String   @map("asset_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  assignedDate     DateTime @map("assigned_date") @db.Date
  returnDate       DateTime? @map("return_date") @db.Date
  condition        String?  @map("return_condition")
  notes            String?
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset            Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee         Employee     @relation("asset_holder", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId, employeeId])
  @@index([assetId, isActive])
  @@map("asset_assignments")
  @@schema("hrm")
}
