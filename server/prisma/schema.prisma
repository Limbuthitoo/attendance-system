model Separation {
  id                String    @id @default(uuid()) @db.Uuid
  orgId             String    @map("org_id") @db.Uuid
  employeeId        String    @map("employee_id") @db.Uuid
  type              String
  reason            String?
  lastWorkingDate   DateTime? @map("last_working_date") @db.Date
  noticePeriodDays  Int       @default(30) @map("notice_period_days")
  status            String    @default("INITIATED")
  exitInterviewDone Boolean?  @map("exit_interview_done")
  exitInterviewNotes String?  @map("exit_interview_notes")
