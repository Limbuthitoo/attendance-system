// ─────────────────────────────────────────────────────────────────────────────
// Attendance SaaS — Prisma Schema (Multi-file)
// Generator + Datasource — must appear exactly once across all files
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "platform", "core", "devices", "attendance", "payroll", "hrm", "crm", "performance", "accounting", "billing"]
}
