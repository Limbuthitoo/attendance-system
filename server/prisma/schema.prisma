  campaignId      String?   @map("campaign_id") @db.Uuid
  createdBy       String    @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client          CrmClient?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignee        Employee?    @relation("crm_lead_assignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator         Employee     @relation("crm_lead_creator", fields: [createdBy], references: [id], onDelete: Cascade)
  campaign        CrmCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  activities      CrmActivity[]

  @@index([orgId, status])
  @@map("crm_leads")
}

model CrmDeal {
  id                String    @id @default(uuid()) @db.Uuid
  orgId             String    @map("org_id") @db.Uuid
  pipelineId        String    @map("pipeline_id") @db.Uuid
  clientId          String?   @map("client_id") @db.Uuid
  title             String
  value             Decimal   @default(0) @db.Decimal(12,2)
  stage             String    @default("Qualification")
  probability       Int       @default(0)
  status            String    @default("OPEN")
  assignedTo        String?   @map("assigned_to") @db.Uuid
  expectedCloseDate DateTime? @map("expected_close_date") @db.Date
  actualCloseDate   DateTime? @map("actual_close_date") @db.Date
  wonAmount         Decimal?  @map("won_amount") @db.Decimal(12,2)
  lostReason        String?   @map("lost_reason")
  notes             String?
  tags              Json      @default("[]")
  createdBy         String    @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")

  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipeline          CrmPipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  client            CrmClient?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignee          Employee?    @relation("crm_deal_assignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator           Employee     @relation("crm_deal_creator", fields: [createdBy], references: [id], onDelete: Cascade)
  activities        CrmActivity[]

  @@index([orgId, pipelineId, status])
  @@map("crm_deals")
}

model CrmActivity {
  id          String    @id @default(uuid()) @db.Uuid
