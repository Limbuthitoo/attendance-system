  status          String    @default("NEW")
  clientId        String?   @map("client_id") @db.Uuid
  assignedTo      String?   @map("assigned_to") @db.Uuid
  notes           String?
  nextFollowUp    DateTime? @map("next_follow_up")
  lastContactedAt DateTime? @map("last_contacted_at")
