  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals       CrmDeal[]

  @@index([orgId])
  @@map("crm_pipelines")
