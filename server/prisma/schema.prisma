  description String?
  clientId    String?   @map("client_id") @db.Uuid
  leadId      String?   @map("lead_id") @db.Uuid
  dealId      String?   @map("deal_id") @db.Uuid
  dueDate     DateTime? @map("due_date")
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  createdBy   String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client      CrmClient?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead        CrmLead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  deal        CrmDeal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  creator     Employee     @relation("crm_activity_creator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([orgId, dueDate])
  @@map("crm_activities")
}

model CrmCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
