// ─────────────────────────────────────────────────────────────────────────────
// Attendance SaaS — Prisma Schema (Phase 1)
// Multi-tenant ready: every tenant-scoped table has orgId
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLATFORM LEVEL — Super-admin managed
// ═══════════════════════════════════════════════════════════════════════════════

model PlatformUser {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  name      String
  role      PlatformRole @default(SUPER_ADMIN)
  failedLoginAttempts Int @default(0) @map("failed_login_attempts")
  lockedUntil DateTime? @map("locked_until")
  refreshTokenHash String? @map("refresh_token_hash")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_users")
}

enum PlatformRole {
  SUPER_ADMIN
  PLATFORM_SUPPORT
}

// ═══════════════════════════════════════════════════════════════════════════════
// ORGANIZATION (TENANT)
// ═══════════════════════════════════════════════════════════════════════════════

model Organization {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  slug               String   @unique
  domain             String?  @unique
  logoUrl            String?  @map("logo_url")
  faviconUrl         String?  @map("favicon_url")
  planId             String?  @map("plan_id") @db.Uuid
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  trialEndsAt        DateTime? @map("trial_ends_at")
  maxEmployees       Int      @default(50) @map("max_employees")
  maxBranches        Int      @default(5) @map("max_branches")
  maxDevices         Int      @default(10) @map("max_devices")
  settings           Json?    @default("{}")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  plan               Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  branches           Branch[]
  employees          Employee[]
  roles              Role[]
  shifts             Shift[]
  workSchedules      WorkSchedule[]
  devices            Device[]
  deviceRawLogs      DeviceRawLog[]
  attendance         Attendance[]
  leaves             Leave[]
  holidays           Holiday[]
  notices            Notice[]
  notifications      Notification[]
  orgSettings        OrgSetting[]
  orgModules         OrgModule[]
  appReleases        AppRelease[]
  auditLogs          AuditLog[]
  deviceEvents       DeviceEvent[]
  employeeCredentials EmployeeCredential[]
  overtimePolicies    OvertimePolicy[]
  overtimeRecords     OvertimeRecord[]
  payrollSummaries    PayrollSummary[]
  leaveQuotas         LeaveQuota[]
  invoices            Invoice[]
  policies            Policy[]
  salaryStructures    SalaryStructure[]
  payslips            Payslip[]
  advanceSalaries     AdvanceSalary[]
  emergencyContacts   EmergencyContact[]
  employeeDocuments   EmployeeDocument[]
  attendanceCorrections AttendanceCorrection[]
  attendancePenaltyPolicy AttendancePenaltyPolicy?
  notificationSettings     OrgNotificationSetting[]
  departments              Department[]
  designations             Designation[]
  taxConfigs               TaxConfig[]
  festivalAdvances         FestivalAdvance[]
  benefitPlans             BenefitPlan[]
  payGrades                PayGrade[]
  salaryRevisions          SalaryRevision[]
  incentivePlans           IncentivePlan[]
  employeeIncentives       EmployeeIncentive[]
  incentiveAdjustments     IncentiveAdjustment[]
  bonusPlans               BonusPlan[]
  employeeBonuses          EmployeeBonus[]
  kpiDefinitions           KpiDefinition[]
  kpiScores                KpiScore[]
  reviewCycles             ReviewCycle[]
  performanceReviews       PerformanceReview[]
  jobPostings              JobPosting[]
  applicants               Applicant[]
  interviews               Interview[]
  onboardingTemplates      OnboardingTemplate[]
  onboardingTasks          OnboardingTask[]
  referrals                Referral[]
  trainingCourses          TrainingCourse[]
  trainingSessions         TrainingSession[]
  certifications           Certification[]
  documentRequests         DocumentRequest[]
  expenseClaims            ExpenseClaim[]
  assets                   Asset[]
  assetAssignments         AssetAssignment[]
  separations              Separation[]
  crmPipelines             CrmPipeline[]
  crmClients               CrmClient[]
  crmContacts              CrmContact[]
  crmLeads                 CrmLead[]
  crmDeals                 CrmDeal[]
  crmActivities            CrmActivity[]
  crmCampaigns             CrmCampaign[]
  crmCampaignMembers       CrmCampaignMember[]
  fiscalYears              FiscalYear[]
  chartOfAccounts          ChartOfAccount[]
  journalEntries           JournalEntry[]
  billingSettings          BillingSettings?
  billingParties           BillingParty[]
  billingInvoices          BillingInvoice[]
  billingPayments          BillingPayment[]
  projects                 Project[]
  projectMembers           ProjectMember[]
  tasks                    Task[]
  leaveBalances            LeaveBalance[]

  @@map("organizations")
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUBSCRIPTION PLANS (platform-managed, customizable)
// ═══════════════════════════════════════════════════════════════════════════════

model Plan {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  code           String   @unique
  description    String   @default("")
  price          Int      @default(0)               // price in smallest currency unit (paisa for NPR)
  currency       String   @default("NPR")
  billingCycle   String   @default("monthly") @map("billing_cycle") // monthly | yearly
  maxEmployees   Int      @default(10) @map("max_employees")
  maxBranches    Int      @default(1) @map("max_branches")
  maxDevices     Int      @default(2) @map("max_devices")
  trialDays      Int      @default(0) @map("trial_days")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  features       Json?    @default("[]")            // array of feature strings
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  backupRetentionDays Int @default(7) @map("backup_retention_days")

  organizations  Organization[]
  invoices       Invoice[]

  @@map("plans")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLATFORM SETTINGS (global key-value config for SaaS platform)
// ═══════════════════════════════════════════════════════════════════════════════

model PlatformSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  label     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ═══════════════════════════════════════════════════════════════════════════════
// INVOICES (billing & payment tracking)
// ═══════════════════════════════════════════════════════════════════════════════

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  invoiceNumber  String        @unique @map("invoice_number")
  orgId          String        @map("org_id") @db.Uuid
  planId         String?       @map("plan_id") @db.Uuid
  amount         Int           @default(0)               // in paisa
  currency       String        @default("NPR")
  status         InvoiceStatus @default(PENDING)
  billingPeriodStart DateTime  @map("billing_period_start")
  billingPeriodEnd   DateTime  @map("billing_period_end")
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  paymentMethod  String?       @map("payment_method")    // bank_transfer, esewa, khalti, cash, etc.
  paymentRef     String?       @map("payment_ref")       // transaction reference
  notes          String        @default("")
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan           Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

// ═══════════════════════════════════════════════════════════════════════════════
// BRANCH (sub-tenant within an organization)
// ═══════════════════════════════════════════════════════════════════════════════

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  code      String
  address   String?
  city      String?
  country   String   @default("Nepal")
  timezone  String   @default("Asia/Kathmandu")
  // Geofencing
  latitude  Decimal? @db.Decimal(10,7)
  longitude Decimal? @db.Decimal(10,7)
  geofenceRadius Int? @map("geofence_radius")  // meters
  geofenceEnabled Boolean @default(false) @map("geofence_enabled")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeAssignments EmployeeAssignment[]
  devices             Device[]
  shifts              Shift[]
  attendance          Attendance[]
  deviceEvents        DeviceEvent[]

  @@unique([orgId, code])
  @@map("branches")
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODULE / FEATURE LICENSING
// ═══════════════════════════════════════════════════════════════════════════════

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  orgModules  OrgModule[]

  @@map("modules")
}

model OrgModule {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  moduleId  String   @map("module_id") @db.Uuid
  config    Json?    @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  enabledAt DateTime @default(now()) @map("enabled_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  module    Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleId])
  @@map("org_modules")
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMPLOYEE
// ═══════════════════════════════════════════════════════════════════════════════

model Employee {
  id                 String   @id @default(uuid()) @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  employeeCode       String   @map("employee_code")
  name               String
  email              String
  password           String
  department         String   @default("General")
  designation        String   @default("Employee")
  gender             String?  // male, female, other
  joinDate           DateTime? @map("join_date") @db.Date
  employmentStatus   String   @default("active") @map("employment_status") // active, probation, notice_period
  phone              String?
  avatarUrl          String?  @map("avatar_url")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  lockedUntil        DateTime? @map("locked_until")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Personal Info
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  bloodGroup         String?   @map("blood_group")
  maritalStatus      String?   @map("marital_status") // single, married, divorced, widowed
  address            String?
  city               String?
  state              String?
  country            String?   @default("Nepal")
  zipCode            String?   @map("zip_code")

  // Employment Info
  contractType       String?   @map("contract_type") // permanent, contract, part_time, intern
  probationEndDate   DateTime? @map("probation_end_date") @db.Date
  panNumber          String?   @map("pan_number")
  ssfNumber          String?   @map("ssf_number")

  // Bank Details
  bankName           String?   @map("bank_name")
  bankBranch         String?   @map("bank_branch")
  bankAccountNumber  String?   @map("bank_account_number")
  bankAccountName    String?   @map("bank_account_name")

  // Relations
  org                Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeRoles      EmployeeRole[]
  assignments        EmployeeAssignment[]
  credentials        EmployeeCredential[]
  attendance         Attendance[]
  leaves             Leave[]              @relation("employee_leaves")
  reviewedLeaves     Leave[]              @relation("reviewed_leaves")
  pushTokens         PushToken[]
  notifications      Notification[]
  refreshTokens      RefreshToken[]
  appReleases        AppRelease[]
  noticesPublished    Notice[]
  deviceEvents        DeviceEvent[]
  deviceWriteJobs     DeviceWriteJob[]
  overtimeRecords     OvertimeRecord[]
  overtimeApprovals   OvertimeRecord[] @relation("overtime_approver")
  payrollSummaries    PayrollSummary[]
  leaveQuotas         LeaveQuota[]
  policiesCreated     Policy[]
  salaryStructures    SalaryStructure[]
  payslips            Payslip[]
  advanceSalaries     AdvanceSalary[]
  emergencyContacts   EmergencyContact[]
  documents           EmployeeDocument[]
  attendanceCorrections   AttendanceCorrection[] @relation("employee_corrections")
  correctionReviews       AttendanceCorrection[] @relation("correction_reviewer")
  notificationPrefs       EmployeeNotificationPref[]
  festivalAdvances        FestivalAdvance[]
  salaryRevisions         SalaryRevision[]
  employeeIncentives      EmployeeIncentive[]
  employeeBonuses         EmployeeBonus[]
  kpiScores               KpiScore[]
  performanceAsEmployee   PerformanceReview[] @relation("performance_employee")
  performanceAsReviewer   PerformanceReview[] @relation("performance_reviewer")
  interviews              Interview[]
  onboardingTasks         OnboardingTask[]
  referralsMade           Referral[] @relation("referrals_made")
  trainingAsSessions      TrainingSession[] @relation("training_trainer")
  trainingEnrollments     TrainingEnrollment[]
  certifications          Certification[]
  documentRequests        DocumentRequest[] @relation("doc_request_employee")
  documentProcessed       DocumentRequest[] @relation("doc_request_processor")
  expenseClaims           ExpenseClaim[]    @relation("expense_employee")
  expenseApprovals        ExpenseClaim[]    @relation("expense_approver")
  assetAssignments        AssetAssignment[]
  separations             Separation[]
  clearanceApprovals      ClearanceItem[]   @relation("clearance_approver")
  bonusPlansCreated       BonusPlan[]       @relation("bonus_plan_creator")
  incentiveReviews        EmployeeIncentive[] @relation("incentive_reviewer")
  taskCreated             Task[]            @relation("task_creator")
  referralHired           Referral[]        @relation("referral_hired")
  journalCreated          JournalEntry[]    @relation("journal_creator")
  journalApproved         JournalEntry[]    @relation("journal_approver")
  crmLeadAssignee         CrmLead[]         @relation("crm_lead_assignee")
  crmLeadCreator          CrmLead[]         @relation("crm_lead_creator")
  crmDealAssignee         CrmDeal[]         @relation("crm_deal_assignee")
  crmDealCreator          CrmDeal[]         @relation("crm_deal_creator")
  crmClientCreator        CrmClient[]       @relation("crm_client_creator")
  crmActivityCreator      CrmActivity[]     @relation("crm_activity_creator")
  crmCampaignCreator      CrmCampaign[]     @relation("crm_campaign_creator")
  projectManager          Project[] @relation("project_manager")
  projectMemberships      ProjectMember[]
  taskAssignee            Task[] @relation("task_assignee")
  leaveBalances           LeaveBalance[]

  @@unique([orgId, email])
  @@unique([orgId, employeeCode])
  @@index([orgId, isActive])
  @@map("employees")
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMERGENCY CONTACTS
// ═══════════════════════════════════════════════════════════════════════════════

model EmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  name         String
  relationship String
  phone        String
  email        String?
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("emergency_contacts")
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMPLOYEE DOCUMENTS
// ═══════════════════════════════════════════════════════════════════════════════

model EmployeeDocument {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  name         String
  type         String   // citizenship, pan_card, contract, certificate, other
  filePath     String   @map("file_path")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_documents")
}

// ═══════════════════════════════════════════════════════════════════════════════
// RBAC — Roles & Permissions
// ═══════════════════════════════════════════════════════════════════════════════

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String?  @map("org_id") @db.Uuid
  name        String
  description String?
  permissions Json     @default("[]")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org           Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeRoles EmployeeRole[]

  @@unique([orgId, name])
  @@map("roles")
}

model EmployeeRole {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  grantedAt  DateTime @default(now()) @map("granted_at")
  grantedBy  String?  @map("granted_by") @db.Uuid

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, roleId, branchId])
  @@map("employee_roles")
}

// ═══════════════════════════════════════════════════════════════════════════════
// SHIFT & WORK SCHEDULE
// ═══════════════════════════════════════════════════════════════════════════════

model Shift {
  id                  String    @id @default(uuid()) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  branchId            String?   @map("branch_id") @db.Uuid
  name                String
  shiftType           ShiftType @default(FIXED) @map("shift_type") // FIXED, FLEXIBLE, NIGHT
  startTime           String    @map("start_time")       // "09:00"
  endTime             String    @map("end_time")         // "18:00"
  breakMinutes        Int       @default(0) @map("break_minutes") // lunch/tea break deducted from hours
  lateThresholdMinutes Int      @default(30) @map("late_threshold_minutes")
  halfDayHours        Decimal   @default(4) @map("half_day_hours") @db.Decimal(4,2)
  fullDayHours        Decimal   @default(8) @map("full_day_hours") @db.Decimal(4,2)
  minCheckoutMinutes  Int       @default(2) @map("min_checkout_minutes")
  isDefault           Boolean   @default(false) @map("is_default")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  org                 Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch              Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employeeAssignments EmployeeAssignment[]

  @@map("shifts")
}

enum ShiftType {
  FIXED
  FLEXIBLE
  NIGHT
}

model WorkSchedule {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  name          String                              // "5-Day Week", "6-Day Week"
  workingDays   Json     @map("working_days")       // ["mon","tue","wed","thu","fri"]
  effectiveFrom DateTime @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  org                 Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeAssignments EmployeeAssignment[]

  @@map("work_schedules")
}

model EmployeeAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  employeeId     String    @map("employee_id") @db.Uuid
  branchId       String    @map("branch_id") @db.Uuid
  shiftId        String    @map("shift_id") @db.Uuid
  workScheduleId String    @map("work_schedule_id") @db.Uuid
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  effectiveTo    DateTime? @map("effective_to") @db.Date
  isCurrent      Boolean   @default(true) @map("is_current")
  createdAt      DateTime  @default(now()) @map("created_at")

  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shift          Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)

  @@index([employeeId, isCurrent])
  @@map("employee_assignments")
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEVICES — Unified (NFC, Fingerprint, QR, Face, etc.)
// ═══════════════════════════════════════════════════════════════════════════════

model DeviceCategory {
  id        String        @id @default(uuid()) @db.Uuid
  key       String        @unique               // NFC_RFID, FINGERPRINT, FACE_RECOGNITION, etc.
  name      String                              // "NFC / RFID", "Fingerprint Scanner"
  icon      String?                             // lucide icon name for UI
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  models    DeviceModel[]

  @@map("device_categories")
}

model DeviceBrand {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @unique               // "ZKTeco", "Generic PC/SC", "Hikvision"
  website   String?
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  models    DeviceModel[]

  @@map("device_brands")
}

model DeviceModel {
  id                 String         @id @default(uuid()) @db.Uuid
  categoryId         String         @map("category_id") @db.Uuid
  brandId            String         @map("brand_id") @db.Uuid
  name               String                              // "ACR122U", "K40", "DS-K1T341"
  adapterKey         String?        @map("adapter_key")  // null = regular device, "zkteco" = needs adapter
  connectionType     ConnectionType @map("connection_type")
  syncMode           SyncMode       @default(PUSH) @map("sync_mode")
  setupSchema        Json?          @map("setup_schema")         // dynamic config field definitions
  eventMappingSchema Json?          @map("event_mapping_schema") // raw → normalized field mapping
  capabilities       Json?                                       // { supports_realtime, supports_card, etc. }
  supportedActions   String[]       @default([]) @map("supported_actions") // ["CHECK_IN","CHECK_OUT"]
  isActive           Boolean        @default(true) @map("is_active")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  category           DeviceCategory @relation(fields: [categoryId], references: [id])
  brand              DeviceBrand    @relation(fields: [brandId], references: [id])
  devices            Device[]

  @@unique([brandId, name])
  @@index([categoryId])
  @@map("device_models")
}

enum ConnectionType {
  LOCAL_USB
  LOCAL_PCSC
  LAN_TCP_IP
  HTTP_API
  WEBHOOK
  SDK
  FILE_IMPORT
  CLOUD_API
}

enum SyncMode {
  PUSH
  PULL
  REALTIME
  SCHEDULED
  MANUAL_IMPORT
  OFFLINE_SYNC
}

model Device {
  id              String        @id @default(uuid()) @db.Uuid
  orgId           String        @map("org_id") @db.Uuid
  branchId        String?       @map("branch_id") @db.Uuid
  modelId         String?       @map("model_id") @db.Uuid
  deviceType      DeviceType    @map("device_type")
  deviceSerial    String        @unique @map("device_serial")
  name            String?
  brand           String?
  model           String?
  location        String?
  apiKeyHash      String        @map("api_key_hash")   // bcrypt hashed per-device key
  firmwareVersion String?       @map("firmware_version")
  deviceConfig    Json?         @map("device_config")  // instance-specific config (encrypted sensitive fields)
  healthStatus    DeviceHealth  @default(ONLINE) @map("health_status")
  failedSyncCount Int           @default(0) @map("failed_sync_count")
  lastSyncAt      DateTime?     @map("last_sync_at")
  lastHeartbeatAt DateTime?     @map("last_heartbeat_at")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  deviceModel     DeviceModel?  @relation(fields: [modelId], references: [id], onDelete: SetNull)
  deviceEvents    DeviceEvent[]
  writeJobs       DeviceWriteJob[]
  rawLogs         DeviceRawLog[]

  @@index([orgId, deviceType])
  @@map("devices")
}

enum DeviceType {
  NFC_READER
  FINGERPRINT
  QR_TERMINAL
  FACE_RECOGNITION
  ACCESS_CONTROL
  GENERIC_HTTP
}

enum DeviceHealth {
  ONLINE
  OFFLINE
  WARNING
  ERROR
  DISABLED
  GATEWAY_OFFLINE
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEVICE RAW LOGS — Audit trail of all device communication
// ═══════════════════════════════════════════════════════════════════════════════

model DeviceRawLog {
  id               String              @id @default(uuid()) @db.Uuid
  orgId            String              @map("org_id") @db.Uuid
  deviceId         String              @map("device_id") @db.Uuid
  rawPayload       Json                @map("raw_payload")
  processingStatus LogProcessingStatus @default(RECEIVED) @map("processing_status")
  syncBatchId      String?             @map("sync_batch_id")
  errorMessage     String?             @map("error_message")
  receivedAt       DateTime            @default(now()) @map("received_at")
  processedAt      DateTime?           @map("processed_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  device           Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, receivedAt])
  @@index([orgId, processingStatus])
  @@map("device_raw_logs")
}

enum LogProcessingStatus {
  RECEIVED
  NORMALIZED
  PROCESSED
  DUPLICATE
  UNMAPPED
  INVALID
  FAILED
  RETRYING
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMPLOYEE CREDENTIALS — Unified (NFC card, fingerprint, QR, face, PIN)
// ═══════════════════════════════════════════════════════════════════════════════

model EmployeeCredential {
  id             String         @id @default(uuid()) @db.Uuid
  orgId          String         @map("org_id") @db.Uuid
  employeeId     String         @map("employee_id") @db.Uuid
  credentialType CredentialType @map("credential_type")
  credentialData String         @map("credential_data") // card UID, fingerprint hash, QR token, etc.
  label          String?
  isActive       Boolean        @default(true) @map("is_active")
  assignedAt     DateTime       @default(now()) @map("assigned_at")
  deactivatedAt  DateTime?      @map("deactivated_at")

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([credentialType, credentialData])
  @@index([employeeId])
  @@map("employee_credentials")
}

enum CredentialType {
  NFC_CARD
  FINGERPRINT
  QR_CODE
  FACE_ID
  PIN
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEVICE EVENTS — Unified tap/scan audit log
// ═══════════════════════════════════════════════════════════════════════════════

model DeviceEvent {
  id             String          @id @default(uuid()) @db.Uuid
  orgId          String          @map("org_id") @db.Uuid
  branchId       String?         @map("branch_id") @db.Uuid
  deviceId       String          @map("device_id") @db.Uuid
  credentialType CredentialType? @map("credential_type")
  credentialData String?         @map("credential_data")
  employeeId     String?         @map("employee_id") @db.Uuid
  eventType      DeviceEventType @map("event_type")
  result         String
  attendanceId   String?         @map("attendance_id") @db.Uuid
  eventTime      DateTime        @default(now()) @map("event_time")
  metadata       Json?

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  device         Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee       Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  attendance     Attendance?  @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  @@index([deviceId, eventTime])
  @@index([orgId, eventTime])
  @@index([employeeId, eventTime])
  @@map("device_events")
}

enum DeviceEventType {
  CHECK_IN
  CHECK_OUT
  REJECTED
  UNKNOWN
  HEARTBEAT
  AUTO
  BREAK_IN
  BREAK_OUT
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEVICE WRITE JOBS — Provisioning queue (NFC card writing, etc.)
// ═══════════════════════════════════════════════════════════════════════════════

model DeviceWriteJob {
  id             String         @id @default(uuid()) @db.Uuid
  employeeId     String         @map("employee_id") @db.Uuid
  deviceId       String?        @map("device_id") @db.Uuid
  dataToWrite    String         @map("data_to_write")
  status         WriteJobStatus @default(PENDING)
  resultData     String?        @map("result_data")      // e.g. card UID after write
  errorMessage   String?        @map("error_message")
  createdAt      DateTime       @default(now()) @map("created_at")
  completedAt    DateTime?      @map("completed_at")

  device         Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("device_write_jobs")
}

enum WriteJobStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════════════════
// ATTENDANCE
// ═══════════════════════════════════════════════════════════════════════════════

model Attendance {
  id               String           @id @default(uuid()) @db.Uuid
  orgId            String           @map("org_id") @db.Uuid
  employeeId       String           @map("employee_id") @db.Uuid
  branchId         String?          @map("branch_id") @db.Uuid
  date             DateTime         @db.Date
  checkIn          DateTime?        @map("check_in")
  checkOut         DateTime?        @map("check_out")
  status           AttendanceStatus @default(PRESENT)
  source           AttendanceSource @default(MANUAL)
  workHours        Decimal?         @default(0) @map("work_hours") @db.Decimal(5,2)
  breakMinutes     Int?             @default(0) @map("break_minutes")  // break deducted
  lateMinutes      Int?             @default(0) @map("late_minutes")   // minutes late
  earlyExitMinutes Int?             @default(0) @map("early_exit_minutes") // minutes left early
  isLocked         Boolean          @default(false) @map("is_locked")  // locked after payroll
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")

  org        Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch     Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  deviceEvents DeviceEvent[]
  corrections AttendanceCorrection[]

  @@unique([employeeId, date])
  @@index([orgId, date])
  @@index([employeeId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
  ON_LEAVE
  HOLIDAY
  WEEKLY_OFF
  MISSING_CHECKOUT
  EARLY_EXIT
}

enum AttendanceSource {
  MANUAL
  NFC
  FINGERPRINT
  QR_CODE
  FACE_ID
  SYSTEM   // e.g. auto-marked absent from leave approval
}

// ═══════════════════════════════════════════════════════════════════════════════
// ATTENDANCE CORRECTION (Regularization)
// ═══════════════════════════════════════════════════════════════════════════════

model AttendanceCorrection {
  id            String           @id @default(uuid()) @db.Uuid
  orgId         String           @map("org_id") @db.Uuid
  employeeId    String           @map("employee_id") @db.Uuid
  attendanceId  String?          @map("attendance_id") @db.Uuid
  date          DateTime         @db.Date
  correctionType CorrectionType  @map("correction_type") // MISSED_CHECKIN, MISSED_CHECKOUT, WRONG_TIME, OTHER
  requestedCheckIn  DateTime?    @map("requested_check_in")
  requestedCheckOut DateTime?    @map("requested_check_out")
  reason        String
  status        CorrectionStatus @default(PENDING)
  reviewedBy    String?          @map("reviewed_by") @db.Uuid
  reviewNote    String?          @map("review_note")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee      Employee      @relation("employee_corrections", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer      Employee?     @relation("correction_reviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attendance    Attendance?   @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([employeeId, date])
  @@map("attendance_corrections")
}

enum CorrectionType {
  MISSED_CHECKIN
  MISSED_CHECKOUT
  WRONG_TIME
  OTHER
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ═══════════════════════════════════════════════════════════════════════════════
// ATTENDANCE PENALTY POLICY (Late/Early Exit penalties)
// ═══════════════════════════════════════════════════════════════════════════════

model AttendancePenaltyPolicy {
  id                      String   @id @default(uuid()) @db.Uuid
  orgId                   String   @unique @map("org_id") @db.Uuid
  maxLatePerMonth         Int      @default(3) @map("max_late_per_month")
  latePenaltyType         String   @default("half_day_deduction") @map("late_penalty_type") // half_day_deduction, salary_deduction
  maxEarlyExitPerMonth    Int      @default(3) @map("max_early_exit_per_month")
  earlyExitPenaltyType    String   @default("half_day_deduction") @map("early_exit_penalty_type")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  org                     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("attendance_penalty_policies")
}

// ═══════════════════════════════════════════════════════════════════════════════
// LEAVES
// ═══════════════════════════════════════════════════════════════════════════════

model Leave {
  id          String      @id @default(uuid()) @db.Uuid
  orgId       String      @map("org_id") @db.Uuid
  employeeId  String      @map("employee_id") @db.Uuid
  leaveType   LeaveType   @map("leave_type")
  startDate   DateTime    @map("start_date") @db.Date
  endDate     DateTime    @map("end_date") @db.Date
  days        Float
  isHalfDay   Boolean     @default(false) @map("is_half_day")
  reason      String
  status      LeaveStatus @default(PENDING)
  reviewedBy  String?     @map("reviewed_by") @db.Uuid
  reviewNote  String?     @map("review_note")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee    Employee     @relation("employee_leaves", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer    Employee?    @relation("reviewed_leaves", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([employeeId, status])
  @@map("leaves")
}

enum LeaveType {
  SICK
  CASUAL
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════════════════
// HOLIDAYS
// ═══════════════════════════════════════════════════════════════════════════════

model Holiday {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  bsYear     Int      @map("bs_year")
  bsMonth    Int      @map("bs_month")
  bsDay      Int      @map("bs_day")
  bsDayEnd   Int?     @map("bs_day_end")
  bsMonthEnd Int?     @map("bs_month_end")
  name       String
  nameNp     String?  @map("name_np")
  adDate     DateTime? @map("ad_date") @db.Date
  adDateEnd  DateTime? @map("ad_date_end") @db.Date
  womenOnly  Boolean  @default(false) @map("women_only")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, bsYear])
  @@index([orgId, bsYear, bsMonth])
  @@map("holidays")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ORG SETTINGS (key-value per organization)
// ═══════════════════════════════════════════════════════════════════════════════

model OrgSetting {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  key       String
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@map("org_settings")
}

// ═══════════════════════════════════════════════════════════════════════════════
// LEAVE QUOTAS (per organization, overridable per employee)
// ═══════════════════════════════════════════════════════════════════════════════

model LeaveQuota {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  employeeId  String?   @map("employee_id") @db.Uuid  // null = org default
  leaveType   LeaveType @map("leave_type")
  year        Int
  totalDays   Float     @map("total_days")
  usedDays    Float     @default(0) @map("used_days")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee    Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([orgId, employeeId, leaveType, year])
  @@map("leave_quotas")
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOTICES
// ═══════════════════════════════════════════════════════════════════════════════

model Notice {
  id          String     @id @default(uuid()) @db.Uuid
  orgId       String     @map("org_id") @db.Uuid
  title       String
  body        String
  type        NoticeType @default(GENERAL)
  target      String     @default("all")
  publishedBy String     @map("published_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  publisher   Employee     @relation(fields: [publishedBy], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("notices")
}

enum NoticeType {
  GENERAL
  OFFICIAL
  EVENT
  URGENT
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS (per-employee in-app)
// ═══════════════════════════════════════════════════════════════════════════════

model Notification {
  id            String           @id @default(uuid()) @db.Uuid
  orgId         String           @map("org_id") @db.Uuid
  employeeId    String           @map("employee_id") @db.Uuid
  title         String
  body          String
  type          NotificationType @default(NOTICE)
  referenceType String?          @map("reference_type")
  referenceId   String?          @map("reference_id")
  isRead        Boolean          @default(false) @map("is_read")
  isCleared     Boolean          @default(false) @map("is_cleared")
  createdAt     DateTime         @default(now()) @map("created_at")

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isRead, isCleared])
  @@index([orgId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  NOTICE
  LEAVE
  SYSTEM
  CHECKOUT_REMINDER
  REPORT_READY
  PAYROLL_READY
  PAYROLL_ERROR
  BIRTHDAY
  ANNIVERSARY
  ATTENDANCE_ANOMALY
  CRM_ACTIVITY_REMINDER
  CONTRACT_EXPIRY
  BACKUP_ERROR
}

// ═══════════════════════════════════════════════════════════════════════════════
// PUSH TOKENS (Expo push notification tokens)
// ═══════════════════════════════════════════════════════════════════════════════

model PushToken {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  token      String
  deviceName String?  @map("device_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, token])
  @@map("push_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════════
// NOTIFICATION CHANNELS — Org-level notification policies
// ═══════════════════════════════════════════════════════════════════════════════

model OrgNotificationSetting {
  id             String              @id @default(uuid()) @db.Uuid
  orgId          String              @map("org_id") @db.Uuid
  channel        NotificationChannel
  pushEnabled    Boolean             @default(true)  @map("push_enabled")
  emailEnabled   Boolean             @default(true)  @map("email_enabled")
  quietHoursStart String?            @map("quiet_hours_start")  // "22:00"
  quietHoursEnd   String?            @map("quiet_hours_end")    // "07:00"
  titleTemplate   String?            @map("title_template")     // "{{orgName}}: {{title}}"
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, channel])
  @@map("org_notification_settings")
}

model EmployeeNotificationPref {
  id             String              @id @default(uuid()) @db.Uuid
  employeeId     String              @map("employee_id") @db.Uuid
  channel        NotificationChannel
  pushEnabled    Boolean             @default(true) @map("push_enabled")
  emailEnabled   Boolean             @default(true) @map("email_enabled")
  mutedUntil     DateTime?           @map("muted_until")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  employee       Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, channel])
  @@map("employee_notification_prefs")
}

enum NotificationChannel {
  LEAVE_UPDATES
  ATTENDANCE
  NOTICES
  SYSTEM
  BIRTHDAYS
  PAYROLL
  REPORTS
  CRM
}

// ═══════════════════════════════════════════════════════════════════════════════
// REFRESH TOKENS (revocable)
// ═══════════════════════════════════════════════════════════════════════════════

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash")
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════════
// APP RELEASES (APK distribution)
// ═══════════════════════════════════════════════════════════════════════════════

model AppRelease {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  version      String
  filename     String
  fileSize     Int      @map("file_size")
  releaseNotes String   @default("") @map("release_notes")
  isMandatory  Boolean  @default(false) @map("is_mandatory")
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  uploader     Employee?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@map("app_releases")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  actorId    String?  @map("actor_id")           // employee or platform user ID
  actorType  String   @default("employee") @map("actor_type") // "employee" | "platform_user" | "device" | "system"
  action     String                               // "employee.create", "leave.approve", "settings.update"
  resource   String                               // "employee", "leave", "attendance"
  resourceId String?  @map("resource_id")
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, resource, resourceId])
  @@index([actorId])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// OVERTIME POLICY (per organization, optionally per branch)
// ═══════════════════════════════════════════════════════════════════════════════

model OvertimePolicy {
  id                    String   @id @default(uuid()) @db.Uuid
  orgId                 String   @map("org_id") @db.Uuid
  name                  String
  overtimeAfterHours    Decimal  @map("overtime_after_hours") @db.Decimal(4,2) // e.g. 8.00
  maxOvertimeHoursDaily Decimal  @default(4) @map("max_overtime_hours_daily") @db.Decimal(4,2)
  overtimeRateMultiplier Decimal @default(1.5) @map("overtime_rate_multiplier") @db.Decimal(3,2) // 1.5x, 2x
  weekendRateMultiplier  Decimal @default(2.0) @map("weekend_rate_multiplier") @db.Decimal(3,2)
  holidayRateMultiplier  Decimal @default(2.0) @map("holiday_rate_multiplier") @db.Decimal(3,2)
  requiresApproval      Boolean @default(true) @map("requires_approval")
  isActive              Boolean @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  org                   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  overtimeRecords       OvertimeRecord[]

  @@map("overtime_policies")
}

// ═══════════════════════════════════════════════════════════════════════════════
// OVERTIME RECORDS (per employee per day)
// ═══════════════════════════════════════════════════════════════════════════════

model OvertimeRecord {
  id              String          @id @default(uuid()) @db.Uuid
  orgId           String          @map("org_id") @db.Uuid
  employeeId      String          @map("employee_id") @db.Uuid
  policyId        String          @map("policy_id") @db.Uuid
  date            DateTime        @db.Date
  regularHours    Decimal         @map("regular_hours") @db.Decimal(5,2)
  overtimeHours   Decimal         @map("overtime_hours") @db.Decimal(5,2)
  rateMultiplier  Decimal         @map("rate_multiplier") @db.Decimal(3,2)
  status          OvertimeStatus  @default(PENDING)
  approvedBy      String?         @map("approved_by") @db.Uuid
  approvedAt      DateTime?       @map("approved_at")
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")

  org             Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy          OvertimePolicy  @relation(fields: [policyId], references: [id], onDelete: Cascade)
  approver        Employee?       @relation("overtime_approver", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([orgId, date])
  @@index([employeeId, status])
  @@map("overtime_records")
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

