  budget          Decimal?  @db.Decimal(12,2)
  actualCost      Decimal?  @map("actual_cost") @db.Decimal(12,2)
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  tags            Json      @default("[]")
  sentCount       Int       @default(0) @map("sent_count")
  deliveredCount  Int       @default(0) @map("delivered_count")
  openedCount     Int       @default(0) @map("opened_count")
  clickedCount    Int       @default(0) @map("clicked_count")
  respondedCount  Int       @default(0) @map("responded_count")
  convertedCount  Int       @default(0) @map("converted_count")
  revenue         Decimal?  @db.Decimal(12,2)
  createdBy       String    @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator         Employee     @relation("crm_campaign_creator", fields: [createdBy], references: [id], onDelete: Cascade)
  leads           CrmLead[]
  members         CrmCampaignMember[]

  @@index([orgId, status])
  @@map("crm_campaigns")
}

model CrmCampaignMember {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  campaignId   String    @map("campaign_id") @db.Uuid
  clientId     String?   @map("client_id") @db.Uuid
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  status       String    @default("TARGETED")
  respondedAt  DateTime? @map("responded_at")
  convertedAt  DateTime? @map("converted_at")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign     CrmCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  client       CrmClient?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([orgId, campaignId])
  @@map("crm_campaign_members")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ACCOUNTING & BILLING
// ═══════════════════════════════════════════════════════════════════════════════

model FiscalYear {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isCurrent Boolean  @default(false) @map("is_current")
  status    String   @default("OPEN")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  billingInvoices BillingInvoice[]

  @@index([orgId])
  @@map("fiscal_years")
}

model ChartOfAccount {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  code           String
  name           String
  nameNp         String?  @map("name_np")
  type           String
  parentId       String?  @map("parent_id") @db.Uuid
  isGroup        Boolean  @default(false) @map("is_group")
  isSystem       Boolean  @default(false) @map("is_system")
  isActive       Boolean  @default(true) @map("is_active")
  description    String?
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(14,2)

  org            Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent         ChartOfAccount? @relation("account_tree", fields: [parentId], references: [id], onDelete: SetNull)
  children       ChartOfAccount[] @relation("account_tree")
  journalLines   JournalLine[]

  @@unique([orgId, code])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  fiscalYearId  String    @map("fiscal_year_id") @db.Uuid
  entryNumber   Int       @map("entry_number")
  date          DateTime  @db.Date
  narration     String
  reference     String?
  voucherType   String    @default("JOURNAL") @map("voucher_type")
  status        String    @default("DRAFT")
  totalDebit    Decimal   @default(0) @map("total_debit") @db.Decimal(14,2)
  totalCredit   Decimal   @default(0) @map("total_credit") @db.Decimal(14,2)
  createdBy     String    @map("created_by") @db.Uuid
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fiscalYear    FiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  creator       Employee     @relation("journal_creator", fields: [createdBy], references: [id], onDelete: Cascade)
  approver      Employee?    @relation("journal_approver", fields: [approvedBy], references: [id], onDelete: SetNull)
  lines         JournalLine[]
  billingInvoices BillingInvoice[]

  @@index([orgId, fiscalYearId])
  @@map("journal_entries")
}

model JournalLine {
  id         String  @id @default(uuid()) @db.Uuid
  entryId    String  @map("entry_id") @db.Uuid
  accountId  String  @map("account_id") @db.Uuid
  debit      Decimal @default(0) @db.Decimal(14,2)
  credit     Decimal @default(0) @db.Decimal(14,2)
  narration  String?
  costCenter String? @map("cost_center")

  entry      JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account    ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("journal_lines")
}

model BillingSettings {
  id                     String  @id @default(uuid()) @db.Uuid
  orgId                  String  @unique @map("org_id") @db.Uuid
  defaultVatRate         Decimal @default(13) @map("default_vat_rate") @db.Decimal(5,2)
  currency               String  @default("NPR")
  salesPrefix            String  @default("INV") @map("sales_prefix")
  purchasePrefix         String  @default("PUR") @map("purchase_prefix")
  creditNotePrefix       String  @default("CN") @map("credit_note_prefix")
  debitNotePrefix        String  @default("DN") @map("debit_note_prefix")
  receiptPrefix          String  @default("RCT") @map("receipt_prefix")
  paymentVoucherPrefix   String  @default("PV") @map("payment_voucher_prefix")
  invoiceSeqPadding      Int     @default(4) @map("invoice_seq_padding")
  receiptSeqPadding      Int     @default(4) @map("receipt_seq_padding")
  cashAccountCode        String? @map("cash_account_code")
  bankAccountCode        String? @map("bank_account_code")
  receivableAccountCode  String? @map("receivable_account_code")
  payableAccountCode     String? @map("payable_account_code")
  salesRevenueCode       String? @map("sales_revenue_code")
  purchaseExpenseCode    String? @map("purchase_expense_code")
  vatPayableCode         String? @map("vat_payable_code")
  vatReceivableCode      String? @map("vat_receivable_code")
  tdsReceivableCode      String? @map("tds_receivable_code")
  tdsPayableCode         String? @map("tds_payable_code")
  customPaymentMethods   Json?   @map("custom_payment_methods")

  org                    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("billing_settings")
}

model BillingParty {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  name           String
  nameNp         String?  @map("name_np")
  type           String   @default("CUSTOMER")
  panNumber      String?  @map("pan_number")
  vatNumber      String?  @map("vat_number")
  address        String?
  city           String?
  phone          String?
  email          String?
  bankName       String?  @map("bank_name")
  bankAccount    String?  @map("bank_account")
  creditLimit    Decimal? @map("credit_limit") @db.Decimal(14,2)
  creditDays     Int      @default(0) @map("credit_days")
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(14,2)
  isActive       Boolean  @default(true) @map("is_active")

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices       BillingInvoice[]
  payments       BillingPayment[]

  @@index([orgId])
  @@map("billing_parties")
}

model BillingInvoice {
  id                   String    @id @default(uuid()) @db.Uuid
  orgId                String    @map("org_id") @db.Uuid
  fiscalYearId         String    @map("fiscal_year_id") @db.Uuid
  invoiceNumber        String    @map("invoice_number")
  type                 String    @default("SALES")
  partyId              String    @map("party_id") @db.Uuid
  date                 DateTime  @db.Date
  dueDate              DateTime? @map("due_date") @db.Date
  referenceNumber      String?   @map("reference_number")
  subtotal             Decimal   @default(0) @db.Decimal(14,2)
  discountAmount       Decimal   @default(0) @map("discount_amount") @db.Decimal(14,2)
  taxableAmount        Decimal   @default(0) @map("taxable_amount") @db.Decimal(14,2)
  vatAmount            Decimal   @default(0) @map("vat_amount") @db.Decimal(14,2)
  tdsAmount            Decimal   @default(0) @map("tds_amount") @db.Decimal(14,2)
  totalAmount          Decimal   @default(0) @map("total_amount") @db.Decimal(14,2)
  paidAmount           Decimal   @default(0) @map("paid_amount") @db.Decimal(14,2)
  dueAmount            Decimal   @default(0) @map("due_amount") @db.Decimal(14,2)
  vatRate              Decimal   @default(13) @map("vat_rate") @db.Decimal(5,2)
  tdsRate              Decimal   @default(0) @map("tds_rate") @db.Decimal(5,2)
  isVatBill            Boolean   @default(true) @map("is_vat_bill")
  panOfBuyer           String?   @map("pan_of_buyer")
  status               String    @default("DRAFT")
  createdBy            String    @map("created_by") @db.Uuid
  receivableAccountId  String?   @map("receivable_account_id") @db.Uuid
  payableAccountId     String?   @map("payable_account_id") @db.Uuid
  journalEntryId       String?   @map("journal_entry_id") @db.Uuid
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")

  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  party                BillingParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fiscalYear           FiscalYear   @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  journalEntry         JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  items                BillingInvoiceItem[]
  payments             BillingPayment[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId, status])
  @@map("billing_invoices")
}

model BillingInvoiceItem {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  description String
  hsnCode     String? @map("hsn_code")
  quantity    Decimal @default(1) @db.Decimal(10,2)
  unit        String  @default("pcs")
  rate        Decimal @default(0) @db.Decimal(14,2)
  discount    Decimal @default(0) @db.Decimal(14,2)
  amount      Decimal @default(0) @db.Decimal(14,2)
  taxRate     Decimal @default(0) @map("tax_rate") @db.Decimal(5,2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(14,2)
  totalAmount Decimal @default(0) @map("total_amount") @db.Decimal(14,2)

  invoice     BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("billing_invoice_items")
}

model BillingPayment {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  type          String    @default("RECEIVED")
  partyId       String    @map("party_id") @db.Uuid
  invoiceId     String?   @map("invoice_id") @db.Uuid
  receiptNumber String    @map("receipt_number")
  date          DateTime  @db.Date
  amount        Decimal   @db.Decimal(14,2)
  method        String    @default("CASH")
  bankName      String?   @map("bank_name")
  chequeNumber  String?   @map("cheque_number")
  referenceId   String?   @map("reference_id")
  notes         String?
  journalEntryId String?  @map("journal_entry_id") @db.Uuid
  isVoided      Boolean   @default(false) @map("is_voided")
  voidedAt      DateTime? @map("voided_at")
  voidedBy      String?   @map("voided_by") @db.Uuid
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  party         BillingParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  invoice       BillingInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@map("billing_payments")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROJECTS & TASKS
// ═══════════════════════════════════════════════════════════════════════════════

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  description String?
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  budget      Decimal?  @db.Decimal(14,2)
  managerId   String?   @map("manager_id") @db.Uuid
  status      String    @default("ACTIVE")
  progress    Int?      @default(0)
  createdBy   String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  manager     Employee?    @relation("project_manager", fields: [managerId], references: [id], onDelete: SetNull)
  members     ProjectMember[]
  tasks       Task[]

  @@index([orgId, status])
  @@map("projects")
}

model ProjectMember {
  id         String @id @default(uuid()) @db.Uuid
  orgId      String @map("org_id") @db.Uuid
  projectId  String @map("project_id") @db.Uuid
  employeeId String @map("employee_id") @db.Uuid
  role       String @default("member")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
  @@map("project_members")
}

model Task {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  title          String
  description    String?
  status         String    @default("TODO")
  priority       String    @default("MEDIUM")
  assignedTo     String?   @map("assigned_to") @db.Uuid
  projectId      String?   @map("project_id") @db.Uuid
  dueDate        DateTime? @map("due_date") @db.Date
  estimatedHours Decimal?  @map("estimated_hours") @db.Decimal(6,1)
  actualHours    Decimal?  @map("actual_hours") @db.Decimal(6,1)
  tags           Json      @default("[]")
  completedAt    DateTime? @map("completed_at")
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignee       Employee?    @relation("task_assignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        Employee     @relation("task_creator", fields: [createdBy], references: [id], onDelete: Cascade)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@map("tasks")
}

// ═══════════════════════════════════════════════════════════════════════════════
// LEAVE BALANCE (for reporting)
// ═══════════════════════════════════════════════════════════════════════════════

model LeaveBalance {
  id         String  @id @default(uuid()) @db.Uuid
  orgId      String  @map("org_id") @db.Uuid
  year       Int
  employeeId String  @map("employee_id") @db.Uuid
  leaveType  String  @map("leave_type")
  entitled   Decimal @default(0) @db.Decimal(5,1)
  used       Decimal @default(0) @db.Decimal(5,1)
  balance    Decimal @default(0) @db.Decimal(5,1)

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([orgId, employeeId, year, leaveType])
  @@map("leave_balances")
}
