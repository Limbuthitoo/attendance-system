// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM — Super-admin managed (PlatformUser, Plan, Invoice)
// ─────────────────────────────────────────────────────────────────────────────

model PlatformUser {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  name      String
  role      PlatformRole @default(SUPER_ADMIN)
  failedLoginAttempts Int @default(0) @map("failed_login_attempts")
  lockedUntil DateTime? @map("locked_until")
  refreshTokenHash String? @map("refresh_token_hash")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_users")
  @@schema("platform")
}

enum PlatformRole {
  SUPER_ADMIN
  PLATFORM_SUPPORT
  @@schema("platform")
}

model Plan {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  code           String   @unique
  description    String   @default("")
  price          Int      @default(0)
  currency       String   @default("NPR")
  billingCycle   String   @default("monthly") @map("billing_cycle")
  maxEmployees   Int      @default(10) @map("max_employees")
  maxBranches    Int      @default(1) @map("max_branches")
  maxDevices     Int      @default(2) @map("max_devices")
  trialDays      Int      @default(0) @map("trial_days")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  features       Json?    @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizations  Organization[]
  invoices       Invoice[]

  @@map("plans")
  @@schema("platform")
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  invoiceNumber  String        @unique @map("invoice_number")
  orgId          String        @map("org_id") @db.Uuid
  planId         String?       @map("plan_id") @db.Uuid
  amount         Int           @default(0)
  currency       String        @default("NPR")
  status         InvoiceStatus @default(PENDING)
  billingPeriodStart DateTime  @map("billing_period_start")
  billingPeriodEnd   DateTime  @map("billing_period_end")
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  paymentMethod  String?       @map("payment_method")
  paymentRef     String?       @map("payment_ref")
  notes          String        @default("")
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan           Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([status])
  @@map("invoices")
  @@schema("platform")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  @@schema("platform")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
  @@schema("platform")
}
