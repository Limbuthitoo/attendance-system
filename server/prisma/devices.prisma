// ─────────────────────────────────────────────────────────────────────────────
// DEVICES — Unified device management (NFC, Fingerprint, QR, Face, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model DeviceCategory {
  id        String        @id @default(uuid()) @db.Uuid
  key       String        @unique
  name      String
  icon      String?
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  models    DeviceModel[]

  @@map("device_categories")
  @@schema("devices")
}

model DeviceBrand {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @unique
  website   String?
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  models    DeviceModel[]

  @@map("device_brands")
  @@schema("devices")
}

model DeviceModel {
  id                 String         @id @default(uuid()) @db.Uuid
  categoryId         String         @map("category_id") @db.Uuid
  brandId            String         @map("brand_id") @db.Uuid
  name               String
  adapterKey         String?        @map("adapter_key")
  connectionType     ConnectionType @map("connection_type")
  syncMode           SyncMode       @default(PUSH) @map("sync_mode")
  setupSchema        Json?          @map("setup_schema")
  eventMappingSchema Json?          @map("event_mapping_schema")
  capabilities       Json?
  supportedActions   String[]       @default([]) @map("supported_actions")
  isActive           Boolean        @default(true) @map("is_active")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  category           DeviceCategory @relation(fields: [categoryId], references: [id])
  brand              DeviceBrand    @relation(fields: [brandId], references: [id])
  devices            Device[]

  @@unique([brandId, name])
  @@index([categoryId])
  @@map("device_models")
  @@schema("devices")
}

enum ConnectionType {
  LOCAL_USB
  LOCAL_PCSC
  LAN_TCP_IP
  HTTP_API
  WEBHOOK
  SDK
  FILE_IMPORT
  CLOUD_API
  @@schema("devices")
}

enum SyncMode {
  PUSH
  PULL
  REALTIME
  SCHEDULED
  MANUAL_IMPORT
  OFFLINE_SYNC
  @@schema("devices")
}

model Device {
  id              String        @id @default(uuid()) @db.Uuid
  orgId           String        @map("org_id") @db.Uuid
  branchId        String?       @map("branch_id") @db.Uuid
  modelId         String?       @map("model_id") @db.Uuid
  deviceType      DeviceType    @map("device_type")
  deviceSerial    String        @unique @map("device_serial")
  name            String?
  brand           String?
  model           String?
  location        String?
  apiKeyHash      String        @map("api_key_hash")
  firmwareVersion String?       @map("firmware_version")
  deviceConfig    Json?         @map("device_config")
  healthStatus    DeviceHealth  @default(ONLINE) @map("health_status")
  failedSyncCount Int           @default(0) @map("failed_sync_count")
  lastSyncAt      DateTime?     @map("last_sync_at")
  lastHeartbeatAt DateTime?     @map("last_heartbeat_at")
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch          Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  deviceModel     DeviceModel?  @relation(fields: [modelId], references: [id], onDelete: SetNull)
  deviceEvents    DeviceEvent[]
  writeJobs       DeviceWriteJob[]
  rawLogs         DeviceRawLog[]

  @@index([orgId, deviceType])
  @@map("devices")
  @@schema("devices")
}

enum DeviceType {
  NFC_READER
  FINGERPRINT
  QR_TERMINAL
  FACE_RECOGNITION
  ACCESS_CONTROL
  GENERIC_HTTP
  @@schema("devices")
}

enum DeviceHealth {
  ONLINE
  OFFLINE
  WARNING
  ERROR
  DISABLED
  GATEWAY_OFFLINE
  @@schema("devices")
}

model DeviceRawLog {
  id               String              @id @default(uuid()) @db.Uuid
  orgId            String              @map("org_id") @db.Uuid
  deviceId         String              @map("device_id") @db.Uuid
  rawPayload       Json                @map("raw_payload")
  processingStatus LogProcessingStatus @default(RECEIVED) @map("processing_status")
  syncBatchId      String?             @map("sync_batch_id")
  errorMessage     String?             @map("error_message")
  receivedAt       DateTime            @default(now()) @map("received_at")
  processedAt      DateTime?           @map("processed_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  device           Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, receivedAt])
  @@index([orgId, processingStatus])
  @@map("device_raw_logs")
  @@schema("devices")
}

enum LogProcessingStatus {
  RECEIVED
  NORMALIZED
  PROCESSED
  DUPLICATE
  UNMAPPED
  INVALID
  FAILED
  RETRYING
  @@schema("devices")
}

model EmployeeCredential {
  id             String         @id @default(uuid()) @db.Uuid
  orgId          String         @map("org_id") @db.Uuid
  employeeId     String         @map("employee_id") @db.Uuid
  credentialType CredentialType @map("credential_type")
  credentialData String         @map("credential_data")
  label          String?
  isActive       Boolean        @default(true) @map("is_active")
  assignedAt     DateTime       @default(now()) @map("assigned_at")
  deactivatedAt  DateTime?      @map("deactivated_at")

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([credentialType, credentialData])
  @@index([employeeId])
  @@map("employee_credentials")
  @@schema("devices")
}

enum CredentialType {
  NFC_CARD
  FINGERPRINT
  QR_CODE
  FACE_ID
  PIN
  @@schema("devices")
}

model DeviceEvent {
  id             String          @id @default(uuid()) @db.Uuid
  orgId          String          @map("org_id") @db.Uuid
  branchId       String?         @map("branch_id") @db.Uuid
  deviceId       String          @map("device_id") @db.Uuid
  credentialType CredentialType? @map("credential_type")
  credentialData String?         @map("credential_data")
  employeeId     String?         @map("employee_id") @db.Uuid
  eventType      DeviceEventType @map("event_type")
  result         String
  attendanceId   String?         @map("attendance_id") @db.Uuid
  eventTime      DateTime        @default(now()) @map("event_time")
  metadata       Json?

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  device         Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  employee       Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  attendance     Attendance?  @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  @@index([deviceId, eventTime])
  @@index([orgId, eventTime])
  @@index([employeeId, eventTime])
  @@map("device_events")
  @@schema("devices")
}

enum DeviceEventType {
  CHECK_IN
  CHECK_OUT
  REJECTED
  UNKNOWN
  HEARTBEAT
  AUTO
  BREAK_IN
  BREAK_OUT
  @@schema("devices")
}

model DeviceWriteJob {
  id             String         @id @default(uuid()) @db.Uuid
  employeeId     String         @map("employee_id") @db.Uuid
  deviceId       String?        @map("device_id") @db.Uuid
  dataToWrite    String         @map("data_to_write")
  status         WriteJobStatus @default(PENDING)
  resultData     String?        @map("result_data")
  errorMessage   String?        @map("error_message")
  createdAt      DateTime       @default(now()) @map("created_at")
  completedAt    DateTime?      @map("completed_at")

  device         Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("device_write_jobs")
  @@schema("devices")
}

enum WriteJobStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  @@schema("devices")
}
