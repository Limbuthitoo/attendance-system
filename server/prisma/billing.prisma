// ─────────────────────────────────────────────────────────────────────────────
// BILLING — Parties, Invoices, Payments, Settings (Nepal VAT/PAN context)
// ─────────────────────────────────────────────────────────────────────────────

model BillingParty {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  name         String
  nameNp       String?     @map("name_np")
  type         PartyType
  panNumber    String?     @map("pan_number")
  vatNumber    String?     @map("vat_number")
  address      String?
  city         String?
  phone        String?
  email        String?
  bankName     String?     @map("bank_name")
  bankAccount  String?     @map("bank_account")
  creditLimit  Decimal?    @map("credit_limit") @db.Decimal(14, 2)
  creditDays   Int         @default(0) @map("credit_days")
  openingBalance Decimal   @default(0) @map("opening_balance") @db.Decimal(14, 2)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices     BillingInvoice[]
  payments     BillingPayment[]

  @@unique([orgId, panNumber])
  @@index([orgId, type, isActive])
  @@map("billing_parties")
  @@schema("billing")
}

model BillingInvoice {
  id              String        @id @default(uuid()) @db.Uuid
  orgId           String        @map("org_id") @db.Uuid
  fiscalYearId    String        @map("fiscal_year_id") @db.Uuid
  invoiceNumber   String        @map("invoice_number")
  type            BillingInvoiceType
  partyId         String        @map("party_id") @db.Uuid
  date            DateTime      @db.Date
  dueDate         DateTime?     @map("due_date") @db.Date
  referenceNumber String?       @map("reference_number")

  subtotal        Decimal       @db.Decimal(14, 2)
  discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxableAmount   Decimal       @map("taxable_amount") @db.Decimal(14, 2)
  vatAmount       Decimal       @default(0) @map("vat_amount") @db.Decimal(14, 2)
  tdsAmount       Decimal       @default(0) @map("tds_amount") @db.Decimal(14, 2)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(14, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(14, 2)
  dueAmount       Decimal       @map("due_amount") @db.Decimal(14, 2)

  vatRate         Decimal       @default(13) @map("vat_rate") @db.Decimal(5, 2)
  tdsRate         Decimal       @default(0) @map("tds_rate") @db.Decimal(5, 2)
  isVatBill       Boolean       @default(true) @map("is_vat_bill")
  panOfBuyer      String?       @map("pan_of_buyer")

  status          BillingInvoiceStatus @default(DRAFT)
  journalEntryId  String?       @unique @map("journal_entry_id") @db.Uuid
  receivableAccountId String?   @map("receivable_account_id") @db.Uuid
  payableAccountId    String?   @map("payable_account_id") @db.Uuid

  notes           String?       @db.Text
  createdBy       String        @map("created_by") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  org             Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fiscalYear      FiscalYear     @relation(fields: [fiscalYearId], references: [id])
  party           BillingParty   @relation(fields: [partyId], references: [id])
  creator         Employee       @relation("invoice_creator", fields: [createdBy], references: [id])
  journalEntry    JournalEntry?  @relation("invoice_journal", fields: [journalEntryId], references: [id])
  receivableAccount ChartOfAccount? @relation("invoice_receivable_account", fields: [receivableAccountId], references: [id])
  payableAccount    ChartOfAccount? @relation("invoice_payable_account", fields: [payableAccountId], references: [id])
  items           BillingInvoiceItem[]
  payments        BillingPayment[]

  @@unique([orgId, fiscalYearId, invoiceNumber])
  @@index([orgId, type, status])
  @@index([orgId, partyId])
  @@index([orgId, date])
  @@map("billing_invoices")
  @@schema("billing")
}

model BillingInvoiceItem {
  id           String   @id @default(uuid()) @db.Uuid
  invoiceId    String   @map("invoice_id") @db.Uuid
  description  String
  hsnCode      String?  @map("hsn_code")
  quantity     Decimal  @db.Decimal(10, 3)
  unit         String   @default("pcs")
  rate         Decimal  @db.Decimal(14, 2)
  discount     Decimal  @default(0) @db.Decimal(14, 2)
  amount       Decimal  @db.Decimal(14, 2)
  taxRate      Decimal  @default(13) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount    Decimal  @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalAmount  Decimal  @map("total_amount") @db.Decimal(14, 2)

  invoice      BillingInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("billing_invoice_items")
  @@schema("billing")
}

model BillingPayment {
  id           String        @id @default(uuid()) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  type         BillingPaymentType
  partyId      String        @map("party_id") @db.Uuid
  invoiceId    String?       @map("invoice_id") @db.Uuid
  receiptNumber String?      @map("receipt_number")
  date         DateTime      @db.Date
  amount       Decimal       @db.Decimal(14, 2)
  method       PaymentMethod @default(CASH)
  bankName     String?       @map("bank_name")
  chequeNumber String?       @map("cheque_number")
  referenceId  String?       @map("reference_id")
  notes        String?
  journalEntryId String?     @unique @map("journal_entry_id") @db.Uuid
  isVoided     Boolean       @default(false) @map("is_voided")
  voidedAt     DateTime?     @map("voided_at")
  voidedBy     String?       @map("voided_by") @db.Uuid
  createdBy    String        @map("created_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  party        BillingParty  @relation(fields: [partyId], references: [id])
  invoice      BillingInvoice?  @relation(fields: [invoiceId], references: [id])
  journalEntry JournalEntry? @relation("payment_journal", fields: [journalEntryId], references: [id])
  creator      Employee      @relation("payment_creator", fields: [createdBy], references: [id])

  @@index([orgId, type, date])
  @@index([orgId, partyId])
  @@map("billing_payments")
  @@schema("billing")
}

model BillingSettings {
  id              String  @id @default(uuid()) @db.Uuid
  orgId           String  @unique @map("org_id") @db.Uuid

  defaultVatRate  Decimal @default(13) @map("default_vat_rate") @db.Decimal(5, 2)
  currency        String  @default("NPR")

  salesPrefix         String @default("INV") @map("sales_prefix")
  purchasePrefix      String @default("PUR") @map("purchase_prefix")
  creditNotePrefix    String @default("CN") @map("credit_note_prefix")
  debitNotePrefix     String @default("DN") @map("debit_note_prefix")
  receiptPrefix       String @default("RCV") @map("receipt_prefix")
  paymentVoucherPrefix String @default("PAY") @map("payment_voucher_prefix")
  invoiceSeqPadding   Int    @default(4) @map("invoice_seq_padding")
  receiptSeqPadding   Int    @default(5) @map("receipt_seq_padding")

  cashAccountCode         String @default("1101") @map("cash_account_code")
  bankAccountCode         String @default("1102") @map("bank_account_code")
  receivableAccountCode   String @default("1201") @map("receivable_account_code")
  payableAccountCode      String @default("2101") @map("payable_account_code")
  salesRevenueCode        String @default("4100") @map("sales_revenue_code")
  purchaseExpenseCode     String @default("5700") @map("purchase_expense_code")
  vatPayableCode          String @default("2201") @map("vat_payable_code")
  vatReceivableCode       String @default("1500") @map("vat_receivable_code")
  tdsReceivableCode       String @default("1500") @map("tds_receivable_code")
  tdsPayableCode          String @default("2202") @map("tds_payable_code")

  customPaymentMethods    Json?  @map("custom_payment_methods")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("billing_settings")
  @@schema("billing")
}

enum PartyType {
  CUSTOMER
  VENDOR
  BOTH
  @@schema("billing")
}

enum BillingInvoiceType {
  SALES
  PURCHASE
  SALES_RETURN
  PURCHASE_RETURN
  @@schema("billing")
}

enum BillingInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  @@schema("billing")
}

enum BillingPaymentType {
  RECEIVED
  MADE
  @@schema("billing")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  MOBILE_WALLET
  CREDIT_CARD
  OTHER
  @@schema("billing")
}
