// ─────────────────────────────────────────────────────────────────────────────
// CORE — Organization, Employee, Branch, Roles, Shifts, Settings, etc.
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  slug               String   @unique
  domain             String?  @unique
  logoUrl            String?  @map("logo_url")
  faviconUrl         String?  @map("favicon_url")
  planId             String?  @map("plan_id") @db.Uuid
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  trialEndsAt        DateTime? @map("trial_ends_at")
  maxEmployees       Int      @default(50) @map("max_employees")
  maxBranches        Int      @default(5) @map("max_branches")
  maxDevices         Int      @default(10) @map("max_devices")
  settings           Json?    @default("{}")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Core relations
  plan               Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  branches           Branch[]
  employees          Employee[]
  roles              Role[]
  shifts             Shift[]
  workSchedules      WorkSchedule[]
  orgSettings        OrgSetting[]
  orgModules         OrgModule[]
  notices            Notice[]
  notifications      Notification[]
  appReleases        AppRelease[]
  auditLogs          AuditLog[]
  policies            Policy[]
  invoices            Invoice[]
  emergencyContacts   EmergencyContact[]
  employeeDocuments   EmployeeDocument[]
  leaveQuotas         LeaveQuota[]

  // Device relations
  devices            Device[]
  deviceRawLogs      DeviceRawLog[]
  deviceEvents       DeviceEvent[]
  employeeCredentials EmployeeCredential[]

  // Attendance relations
  attendance         Attendance[]
  leaves             Leave[]
  holidays           Holiday[]
  attendanceCorrections AttendanceCorrection[]
  attendancePenaltyPolicy AttendancePenaltyPolicy?

  // Payroll relations
  overtimePolicies    OvertimePolicy[]
  overtimeRecords     OvertimeRecord[]
  payrollSummaries    PayrollSummary[]
  salaryStructures    SalaryStructure[]
  payslips            Payslip[]
  advanceSalaries     AdvanceSalary[]

  // HRM relations
  incentivePlans          IncentivePlan[]
  employeeIncentives      EmployeeIncentive[]
  incentiveAdjustments    IncentiveAdjustment[]
  tasks                   Task[]
  projects                Project[]
  projectMembers          ProjectMember[]
  referrals               Referral[]
  bonusPlans              BonusPlan[]
  employeeBonuses         EmployeeBonus[]

  // CRM relations
  crmPipelines            CrmPipeline[]
  crmClients              CrmClient[]
  crmContacts             CrmContact[]
  crmLeads                CrmLead[]
  crmDeals                CrmDeal[]
  crmActivities           CrmActivity[]
  crmCampaigns            CrmCampaign[]
  crmCampaignMembers      CrmCampaignMember[]

  // Performance relations
  kpiDefinitions          KpiDefinition[]
  kpiScores               KpiScore[]
  reviewCycles            ReviewCycle[]
  performanceReviews      PerformanceReview[]

  // Accounting relations
  fiscalYears             FiscalYear[]
  chartOfAccounts         ChartOfAccount[]
  journalEntries          JournalEntry[]

  // Billing relations
  billingParties          BillingParty[]
  billingInvoices         BillingInvoice[]
  billingPayments         BillingPayment[]
  billingSettings         BillingSettings?

  // Department & Designation relations
  departments         Department[]
  designations        Designation[]

  // Payroll — Statutory
  taxConfigs          TaxConfig[]
  festivalAdvances    FestivalAdvance[]
  salaryRevisions     SalaryRevision[]
  payGrades           PayGrade[]
  benefitPlans        BenefitPlan[]

  // Recruitment & Lifecycle
  jobPostings         JobPosting[]
  applicants          Applicant[]
  interviews          Interview[]
  onboardingTemplates OnboardingTemplate[]
  separations         Separation[]

  // Training
  trainingCourses     TrainingCourse[]
  trainingSessions    TrainingSession[]
  certifications      Certification[]

  // ESS
  documentRequests    DocumentRequest[]
  expenseClaims       ExpenseClaim[]
  assets              Asset[]
  assetAssignments    AssetAssignment[]

  @@map("organizations")
  @@schema("core")
}

model Department {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  code      String?
  parentId  String?  @map("parent_id") @db.Uuid
  headId    String?  @map("head_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("dept_hierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("dept_hierarchy")

  @@unique([orgId, name])
  @@index([orgId, isActive])
  @@map("departments")
  @@schema("core")
}

model Designation {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  name       String
  level      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId, isActive])
  @@map("designations")
  @@schema("core")
}

model Employee {
  id                 String   @id @default(uuid()) @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  employeeCode       String   @map("employee_code")
  name               String
  email              String
  password           String
  department         String   @default("General")
  designation        String   @default("Employee")
  gender             String?
  joinDate           DateTime? @map("join_date") @db.Date
  employmentStatus   String   @default("active") @map("employment_status")
  phone              String?
  avatarUrl          String?  @map("avatar_url")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  lockedUntil        DateTime? @map("locked_until")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Personal Info
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  bloodGroup         String?   @map("blood_group")
  maritalStatus      String?   @map("marital_status")
  address            String?
  city               String?
  state              String?
  country            String?   @default("Nepal")
  zipCode            String?   @map("zip_code")

  // Reporting & Org Structure
  reportingManagerId String?   @map("reporting_manager_id") @db.Uuid

  // Employment Info
  contractType       String?   @map("contract_type")
  contractEndDate    DateTime? @map("contract_end_date") @db.Date
  probationEndDate   DateTime? @map("probation_end_date") @db.Date
  confirmedDate      DateTime? @map("confirmed_date") @db.Date
  panNumber          String?   @map("pan_number")
  ssfNumber          String?   @map("ssf_number")
  citNumber          String?   @map("cit_number")
  pfNumber           String?   @map("pf_number")

  // Bank Details
  bankName           String?   @map("bank_name")
  bankBranch         String?   @map("bank_branch")
  bankAccountNumber  String?   @map("bank_account_number")
  bankAccountName    String?   @map("bank_account_name")

  // Core relations
  org                Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reportingManager   Employee?             @relation("reporting_structure", fields: [reportingManagerId], references: [id])
  directReports      Employee[]            @relation("reporting_structure")
  employeeRoles      EmployeeRole[]
  assignments        EmployeeAssignment[]
  pushTokens         PushToken[]
  notifications      Notification[]
  refreshTokens      RefreshToken[]
  appReleases        AppRelease[]
  noticesPublished    Notice[]
  policiesCreated     Policy[]
  emergencyContacts   EmergencyContact[]
  documents           EmployeeDocument[]
  leaveQuotas         LeaveQuota[]

  // Device relations
  credentials        EmployeeCredential[]
  deviceEvents        DeviceEvent[]
  deviceWriteJobs     DeviceWriteJob[]

  // Attendance relations
  attendance         Attendance[]
  leaves             Leave[]              @relation("employee_leaves")
  reviewedLeaves     Leave[]              @relation("reviewed_leaves")
  attendanceCorrections   AttendanceCorrection[] @relation("employee_corrections")
  correctionReviews       AttendanceCorrection[] @relation("correction_reviewer")

  // Payroll relations
  overtimeRecords     OvertimeRecord[]
  overtimeApprovals   OvertimeRecord[] @relation("overtime_approver")
  payrollSummaries    PayrollSummary[]
  salaryStructures    SalaryStructure[]
  payslips            Payslip[]
  advanceSalaries     AdvanceSalary[]

  // HRM relations
  employeeIncentives       EmployeeIncentive[]    @relation("employee_incentives")
  incentiveReviews         EmployeeIncentive[]    @relation("incentive_reviewer")
  incentiveAdjustments     IncentiveAdjustment[]  @relation("adjustment_creator")
  tasksAssigned            Task[]                 @relation("task_assignee")
  tasksCreated             Task[]                 @relation("task_creator")
  projectsManaged          Project[]              @relation("project_manager")
  projectsCreated          Project[]              @relation("project_creator")
  projectMemberships       ProjectMember[]        @relation("project_member")
  referralsMade            Referral[]             @relation("referral_referrer")
  referralsHired           Referral[]             @relation("referral_hired")
  bonusPlanCreated         BonusPlan[]            @relation("bonus_plan_creator")
  employeeBonuses          EmployeeBonus[]        @relation("employee_bonuses")
  bonusApprovals           EmployeeBonus[]        @relation("bonus_approver")

  // CRM relations
  crmClientsCreated        CrmClient[]            @relation("client_creator")
  crmLeadsAssigned         CrmLead[]              @relation("lead_assignee")
  crmLeadsCreated          CrmLead[]              @relation("lead_creator")
  crmDealsAssigned         CrmDeal[]              @relation("deal_assignee")
  crmDealsCreated          CrmDeal[]              @relation("deal_creator")
  crmActivitiesCreated     CrmActivity[]          @relation("activity_creator")
  crmCampaignsCreated      CrmCampaign[]          @relation("campaign_creator")

  // Performance relations
  kpiDefinitionsCreated    KpiDefinition[]        @relation("kpi_creator")
  kpiScoresEmployee        KpiScore[]             @relation("kpi_employee")
  kpiScoresScorer          KpiScore[]             @relation("kpi_scorer")
  reviewCyclesCreated      ReviewCycle[]           @relation("review_creator")
  performanceReviewsEmployee PerformanceReview[]  @relation("review_employee")
  performanceReviewsReviewer PerformanceReview[]  @relation("review_reviewer")

  // Accounting relations
  journalEntriesCreated    JournalEntry[]         @relation("journal_creator")
  journalEntriesApproved   JournalEntry[]         @relation("journal_approver")

  // Billing relations
  billingInvoicesCreated  BillingInvoice[]       @relation("invoice_creator")
  billingPaymentsCreated   BillingPayment[]       @relation("payment_creator")

  // Payroll — Statutory
  festivalAdvancesReceived FestivalAdvance[]     @relation("advance_employee")
  festivalAdvancesApproved FestivalAdvance[]     @relation("advance_approver")
  salaryRevisions          SalaryRevision[]      @relation("revision_employee")
  salaryRevisionsApproved  SalaryRevision[]      @relation("revision_approver")

  // Recruitment & Lifecycle
  jobPostingsCreated       JobPosting[]          @relation("posting_creator")
  interviewsAsInterviewer  Interview[]           @relation("interviewer")
  onboardingTasksAssigned  OnboardingTask[]      @relation("onboarding_assignee")
  separationsEmployee      Separation[]          @relation("separation_employee")
  separationsProcessedBy   Separation[]          @relation("separation_processor")
  clearanceItemsApproved   ClearanceItem[]       @relation("clearance_approver")

  // Training
  trainingSessionsCreated  TrainingSession[]     @relation("session_trainer")
  trainingEnrollments      TrainingEnrollment[]  @relation("enrollment_employee")
  certificationsHeld       Certification[]       @relation("cert_employee")

  // ESS
  documentRequestsMade     DocumentRequest[]     @relation("doc_requester")
  documentRequestsProcessed DocumentRequest[]    @relation("doc_processor")
  expenseClaimsMade        ExpenseClaim[]        @relation("expense_claimant")
  expenseClaimsApproved    ExpenseClaim[]        @relation("expense_approver")
  assetsAssigned           AssetAssignment[]     @relation("asset_holder")

  @@unique([orgId, email])
  @@unique([orgId, employeeCode])
  @@index([orgId, isActive])
  @@map("employees")
  @@schema("core")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  code      String
  address   String?
  city      String?
  country   String   @default("Nepal")
  timezone  String   @default("Asia/Kathmandu")
  latitude  Decimal? @db.Decimal(10,7)
  longitude Decimal? @db.Decimal(10,7)
  geofenceRadius Int? @map("geofence_radius")
  geofenceEnabled Boolean @default(false) @map("geofence_enabled")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeAssignments EmployeeAssignment[]
  devices             Device[]
  shifts              Shift[]
  attendance          Attendance[]
  deviceEvents        DeviceEvent[]

  @@unique([orgId, code])
  @@map("branches")
  @@schema("core")
}

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  orgModules  OrgModule[]

  @@map("modules")
  @@schema("core")
}

model OrgModule {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  moduleId  String   @map("module_id") @db.Uuid
  config    Json?    @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  enabledAt DateTime @default(now()) @map("enabled_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  module    Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleId])
  @@map("org_modules")
  @@schema("core")
}

model EmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  name         String
  relationship String
  phone        String
  email        String?
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("emergency_contacts")
  @@schema("core")
}

model EmployeeDocument {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  name         String
  type         String
  filePath     String   @map("file_path")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_documents")
  @@schema("core")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String?  @map("org_id") @db.Uuid
  name        String
  description String?
  permissions Json     @default("[]")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org           Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeRoles EmployeeRole[]

  @@unique([orgId, name])
  @@map("roles")
  @@schema("core")
}

model EmployeeRole {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  grantedAt  DateTime @default(now()) @map("granted_at")
  grantedBy  String?  @map("granted_by") @db.Uuid

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, roleId, branchId])
  @@map("employee_roles")
  @@schema("core")
}

model Shift {
  id                  String    @id @default(uuid()) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  branchId            String?   @map("branch_id") @db.Uuid
  name                String
  shiftType           ShiftType @default(FIXED) @map("shift_type")
  startTime           String    @map("start_time")
  endTime             String    @map("end_time")
  breakMinutes        Int       @default(0) @map("break_minutes")
  lateThresholdMinutes Int      @default(30) @map("late_threshold_minutes")
  halfDayHours        Decimal   @default(4) @map("half_day_hours") @db.Decimal(4,2)
  fullDayHours        Decimal   @default(8) @map("full_day_hours") @db.Decimal(4,2)
  minCheckoutMinutes  Int       @default(2) @map("min_checkout_minutes")
  isDefault           Boolean   @default(false) @map("is_default")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  org                 Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch              Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employeeAssignments EmployeeAssignment[]

  @@map("shifts")
  @@schema("core")
}

enum ShiftType {
  FIXED
  FLEXIBLE
  NIGHT
  @@schema("core")
}

model WorkSchedule {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  name          String
  workingDays   Json     @map("working_days")
  effectiveFrom DateTime @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  org                 Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employeeAssignments EmployeeAssignment[]

  @@map("work_schedules")
  @@schema("core")
}

model EmployeeAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  employeeId     String    @map("employee_id") @db.Uuid
  branchId       String    @map("branch_id") @db.Uuid
  shiftId        String    @map("shift_id") @db.Uuid
  workScheduleId String    @map("work_schedule_id") @db.Uuid
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  effectiveTo    DateTime? @map("effective_to") @db.Date
  isCurrent      Boolean   @default(true) @map("is_current")
  createdAt      DateTime  @default(now()) @map("created_at")

  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch         Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shift          Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)

  @@index([employeeId, isCurrent])
  @@map("employee_assignments")
  @@schema("core")
}

model OrgSetting {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  key       String
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@map("org_settings")
  @@schema("core")
}

model Notice {
  id          String     @id @default(uuid()) @db.Uuid
  orgId       String     @map("org_id") @db.Uuid
  title       String
  body        String
  type        NoticeType @default(GENERAL)
  target      String     @default("all")
  publishedBy String     @map("published_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  publisher   Employee     @relation(fields: [publishedBy], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("notices")
  @@schema("core")
}

enum NoticeType {
  GENERAL
  OFFICIAL
  EVENT
  URGENT
  @@schema("core")
}

model Notification {
  id            String           @id @default(uuid()) @db.Uuid
  orgId         String           @map("org_id") @db.Uuid
  employeeId    String           @map("employee_id") @db.Uuid
  title         String
  body          String
  type          NotificationType @default(NOTICE)
  referenceType String?          @map("reference_type")
  referenceId   String?          @map("reference_id")
  isRead        Boolean          @default(false) @map("is_read")
  isCleared     Boolean          @default(false) @map("is_cleared")
  createdAt     DateTime         @default(now()) @map("created_at")

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, isRead, isCleared])
  @@index([orgId, createdAt])
  @@map("notifications")
  @@schema("core")
}

enum NotificationType {
  NOTICE
  LEAVE
  SYSTEM
  CHECKOUT_REMINDER
  REPORT_READY
  PAYROLL_READY
  PAYROLL_ERROR
  BIRTHDAY
  ANNIVERSARY
  ATTENDANCE_ANOMALY
  CRM_ACTIVITY_REMINDER
  CONTRACT_EXPIRY
  BACKUP_ERROR
  @@schema("core")
}

model PushToken {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  token      String
  deviceName String?  @map("device_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, token])
  @@map("push_tokens")
  @@schema("core")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash")
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("refresh_tokens")
  @@schema("core")
}

model AppRelease {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  version      String
  filename     String
  fileSize     Int      @map("file_size")
  releaseNotes String   @default("") @map("release_notes")
  isMandatory  Boolean  @default(false) @map("is_mandatory")
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  uploader     Employee?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@map("app_releases")
  @@schema("core")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  actorId    String?  @map("actor_id")
  actorType  String   @default("employee") @map("actor_type")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, resource, resourceId])
  @@index([actorId])
  @@map("audit_logs")
  @@schema("core")
}

model Policy {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  title       String
  category    String
  content     String   @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator     Employee?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orgId, category])
  @@map("policies")
  @@schema("core")
}
