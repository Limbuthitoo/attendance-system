// ─────────────────────────────────────────────────────────────────────────────
// ACCOUNTING — Fiscal Years, Chart of Accounts, Journal Entries
// ─────────────────────────────────────────────────────────────────────────────

model FiscalYear {
  id           String           @id @default(uuid()) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  name         String
  startDate    DateTime         @map("start_date") @db.Date
  endDate      DateTime         @map("end_date") @db.Date
  isCurrent    Boolean          @default(false) @map("is_current")
  status       FiscalYearStatus @default(OPEN)
  createdAt    DateTime         @default(now()) @map("created_at")

  org          Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  invoices     BillingInvoice[]

  @@unique([orgId, name])
  @@index([orgId, isCurrent])
  @@map("fiscal_years")
  @@schema("accounting")
}

model ChartOfAccount {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  code         String
  name         String
  nameNp       String?     @map("name_np")
  type         AccountType
  parentId     String?     @map("parent_id") @db.Uuid
  isGroup      Boolean     @default(false) @map("is_group")
  isSystem     Boolean     @default(false) @map("is_system")
  description  String?
  openingBalance Decimal   @default(0) @map("opening_balance") @db.Decimal(14, 2)
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  org          Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent       ChartOfAccount?  @relation("account_hierarchy", fields: [parentId], references: [id])
  children     ChartOfAccount[] @relation("account_hierarchy")
  journalLines JournalLine[]
  invoicesReceivable BillingInvoice[] @relation("invoice_receivable_account")
  invoicesPayable    BillingInvoice[] @relation("invoice_payable_account")

  @@unique([orgId, code])
  @@index([orgId, type, isActive])
  @@map("chart_of_accounts")
  @@schema("accounting")
}

model JournalEntry {
  id           String             @id @default(uuid()) @db.Uuid
  orgId        String             @map("org_id") @db.Uuid
  fiscalYearId String             @map("fiscal_year_id") @db.Uuid
  entryNumber  Int                @map("entry_number")
  date         DateTime           @db.Date
  narration    String
  reference    String?
  voucherType  VoucherType        @default(JOURNAL) @map("voucher_type")
  status       JournalStatus      @default(DRAFT)
  totalDebit   Decimal            @default(0) @map("total_debit") @db.Decimal(14, 2)
  totalCredit  Decimal            @default(0) @map("total_credit") @db.Decimal(14, 2)
  createdBy    String             @map("created_by") @db.Uuid
  approvedBy   String?            @map("approved_by") @db.Uuid
  approvedAt   DateTime?          @map("approved_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  org          Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fiscalYear   FiscalYear         @relation(fields: [fiscalYearId], references: [id])
  creator      Employee           @relation("journal_creator", fields: [createdBy], references: [id])
  approver     Employee?          @relation("journal_approver", fields: [approvedBy], references: [id])
  lines        JournalLine[]
  invoice      BillingInvoice?    @relation("invoice_journal")
  payment      BillingPayment?    @relation("payment_journal")

  @@unique([orgId, fiscalYearId, entryNumber])
  @@index([orgId, date])
  @@index([orgId, voucherType, status])
  @@map("journal_entries")
  @@schema("accounting")
}

model JournalLine {
  id           String         @id @default(uuid()) @db.Uuid
  entryId      String         @map("entry_id") @db.Uuid
  accountId    String         @map("account_id") @db.Uuid
  debit        Decimal        @default(0) @db.Decimal(14, 2)
  credit       Decimal        @default(0) @db.Decimal(14, 2)
  narration    String?
  costCenter   String?        @map("cost_center")

  entry        JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
  @@schema("accounting")
}

enum FiscalYearStatus {
  OPEN
  CLOSED
  LOCKED
  @@schema("accounting")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
  @@schema("accounting")
}

enum VoucherType {
  JOURNAL
  PAYMENT
  RECEIPT
  CONTRA
  SALES
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE
  @@schema("accounting")
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
  @@schema("accounting")
}
