// ─────────────────────────────────────────────────────────────────────────────
// PAYROLL — Overtime, Payroll Summary, Salary, Payslips, Advance Salary
// ─────────────────────────────────────────────────────────────────────────────

model OvertimePolicy {
  id                    String   @id @default(uuid()) @db.Uuid
  orgId                 String   @map("org_id") @db.Uuid
  name                  String
  overtimeAfterHours    Decimal  @map("overtime_after_hours") @db.Decimal(4,2)
  maxOvertimeHoursDaily Decimal  @default(4) @map("max_overtime_hours_daily") @db.Decimal(4,2)
  overtimeRateMultiplier Decimal @default(1.5) @map("overtime_rate_multiplier") @db.Decimal(3,2)
  weekendRateMultiplier  Decimal @default(2.0) @map("weekend_rate_multiplier") @db.Decimal(3,2)
  holidayRateMultiplier  Decimal @default(2.0) @map("holiday_rate_multiplier") @db.Decimal(3,2)
  requiresApproval      Boolean @default(true) @map("requires_approval")
  isActive              Boolean @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  org                   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  overtimeRecords       OvertimeRecord[]

  @@map("overtime_policies")
  @@schema("payroll")
}

model OvertimeRecord {
  id              String          @id @default(uuid()) @db.Uuid
  orgId           String          @map("org_id") @db.Uuid
  employeeId      String          @map("employee_id") @db.Uuid
  policyId        String          @map("policy_id") @db.Uuid
  date            DateTime        @db.Date
  regularHours    Decimal         @map("regular_hours") @db.Decimal(5,2)
  overtimeHours   Decimal         @map("overtime_hours") @db.Decimal(5,2)
  rateMultiplier  Decimal         @map("rate_multiplier") @db.Decimal(3,2)
  status          OvertimeStatus  @default(PENDING)
  approvedBy      String?         @map("approved_by") @db.Uuid
  approvedAt      DateTime?       @map("approved_at")
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")

  org             Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy          OvertimePolicy  @relation(fields: [policyId], references: [id], onDelete: Cascade)
  approver        Employee?       @relation("overtime_approver", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([orgId, date])
  @@index([employeeId, status])
  @@map("overtime_records")
  @@schema("payroll")
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
  @@schema("payroll")
}

model PayrollSummary {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  year             Int
  month            Int
  totalWorkDays    Int      @map("total_work_days")
  presentDays      Int      @map("present_days")
  absentDays       Int      @map("absent_days")
  lateDays         Int      @map("late_days")
  halfDays         Int      @map("half_days")
  leaveDays        Int      @map("leave_days")
  holidayDays      Int      @map("holiday_days")
  weeklyOffDays    Int      @default(0) @map("weekly_off_days")
  earlyExitDays    Int      @default(0) @map("early_exit_days")
  totalWorkHours   Decimal  @map("total_work_hours") @db.Decimal(7,2)
  overtimeHours    Decimal  @default(0) @map("overtime_hours") @db.Decimal(7,2)
  effectiveDays    Decimal  @map("effective_days") @db.Decimal(5,2)
  penaltyDays      Decimal  @default(0) @map("penalty_days") @db.Decimal(5,2)
  generatedAt      DateTime @default(now()) @map("generated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([orgId, employeeId, year, month])
  @@index([orgId, year, month])
  @@map("payroll_summaries")
  @@schema("payroll")
}

model SalaryStructure {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  grossSalary      Decimal  @map("gross_salary") @db.Decimal(12,2)
  basicSalary      Decimal  @map("basic_salary") @db.Decimal(12,2)
  allowances       Json     @default("{}")
  effectiveFrom    DateTime @map("effective_from") @db.Date
  effectiveTo      DateTime? @map("effective_to") @db.Date
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId, employeeId, isActive])
  @@map("salary_structures")
  @@schema("payroll")
}

model Payslip {
  id                  String   @id @default(uuid()) @db.Uuid
  orgId               String   @map("org_id") @db.Uuid
  employeeId          String   @map("employee_id") @db.Uuid
  year                Int
  month               Int

  basicSalary         Decimal  @map("basic_salary") @db.Decimal(12,2)
  allowances          Json     @default("{}")
  overtimeAmount      Decimal  @default(0) @map("overtime_amount") @db.Decimal(12,2)
  incentiveAmount     Decimal  @default(0) @map("incentive_amount") @db.Decimal(12,2)
  bonus               Decimal  @default(0) @db.Decimal(12,2)
  grossEarnings       Decimal  @map("gross_earnings") @db.Decimal(12,2)

  employeeSsf         Decimal  @default(0) @map("employee_ssf") @db.Decimal(12,2)
  employerSsf         Decimal  @default(0) @map("employer_ssf") @db.Decimal(12,2)
  tds                 Decimal  @default(0) @db.Decimal(12,2)
  unpaidLeaveDeduction Decimal @default(0) @map("unpaid_leave_deduction") @db.Decimal(12,2)
  absenceDeduction    Decimal  @default(0) @map("absence_deduction") @db.Decimal(12,2)
  advanceSalaryDeduction Decimal @default(0) @map("advance_salary_deduction") @db.Decimal(12,2)
  otherDeductions     Json     @default("{}") @map("other_deductions")
  totalDeductions     Decimal  @map("total_deductions") @db.Decimal(12,2)

  netSalary           Decimal  @map("net_salary") @db.Decimal(12,2)
  companyCost         Decimal  @default(0) @map("company_cost") @db.Decimal(12,2)

  totalWorkDays       Int      @map("total_work_days")
  presentDays         Int      @map("present_days")
  absentDays          Int      @map("absent_days")
  unpaidLeaveDays     Float    @default(0) @map("unpaid_leave_days")
  overtimeHours       Decimal  @default(0) @map("overtime_hours") @db.Decimal(7,2)

  status              PayslipStatus @default(DRAFT)
  lockedAt            DateTime? @map("locked_at")
  lockedBy            String?   @map("locked_by") @db.Uuid
  notes               String?   @db.Text
  generatedAt         DateTime  @default(now()) @map("generated_at")

  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee            Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([orgId, employeeId, year, month])
  @@index([orgId, year, month])
  @@index([orgId, status])
  @@map("payslips")
  @@schema("payroll")
}

enum PayslipStatus {
  DRAFT
  LOCKED
  PAID
  @@schema("payroll")
}

model AdvanceSalary {
  id                String   @id @default(uuid()) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  employeeId        String   @map("employee_id") @db.Uuid
  description       String?
  totalAmount       Decimal  @map("total_amount") @db.Decimal(12,2)
  remainingAmount   Decimal  @map("remaining_amount") @db.Decimal(12,2)
  monthlyDeduction  Decimal  @map("monthly_deduction") @db.Decimal(12,2)
  startMonth        Int      @map("start_month")
  startYear         Int      @map("start_year")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee          Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([orgId, employeeId, isActive])
  @@map("advance_salaries")
  @@schema("payroll")
}

// ─────────────────────────────────────────────────────────────────────────────
// STATUTORY COMPLIANCE — Nepal Tax, SSF, CIT, PF, Festival Advance
// ─────────────────────────────────────────────────────────────────────────────

model TaxConfig {
  id                    String   @id @default(uuid()) @db.Uuid
  orgId                 String   @map("org_id") @db.Uuid
  fiscalYear            String   @map("fiscal_year")

  // SSF Rates
  ssfEmployeeRate       Decimal  @default(11) @map("ssf_employee_rate") @db.Decimal(5,2)
  ssfEmployerRate       Decimal  @default(20) @map("ssf_employer_rate") @db.Decimal(5,2)
  ssfBaseSalaryOnly     Boolean  @default(true) @map("ssf_base_salary_only")

  // CIT
  citEmployeeRate       Decimal  @default(0) @map("cit_employee_rate") @db.Decimal(5,2)
  citEmployerRate       Decimal  @default(0) @map("cit_employer_rate") @db.Decimal(5,2)

  // Provident Fund
  pfEmployeeRate        Decimal  @default(10) @map("pf_employee_rate") @db.Decimal(5,2)
  pfEmployerRate        Decimal  @default(10) @map("pf_employer_rate") @db.Decimal(5,2)

  // TDS (Tax Deducted at Source) — Nepal income tax slabs stored as JSON
  // Format: [{ min: 0, max: 500000, rate: 1 }, { min: 500000, max: 700000, rate: 10 }, ...]
  taxSlabs              Json     @default("[]") @map("tax_slabs")
  marriedTaxSlabs       Json     @default("[]") @map("married_tax_slabs")

  // Insurance / Gratuity
  gratuityEnabled       Boolean  @default(true) @map("gratuity_enabled")
  gratuityRate          Decimal  @default(8.33) @map("gratuity_rate") @db.Decimal(5,2)

  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  org                   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, fiscalYear])
  @@map("tax_configs")
  @@schema("payroll")
}

model FestivalAdvance {
  id                String   @id @default(uuid()) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  employeeId        String   @map("employee_id") @db.Uuid
  festivalName      String   @map("festival_name")
  fiscalYear        String   @map("fiscal_year")
  amount            Decimal  @db.Decimal(12,2)
  deductionMonths   Int      @default(10) @map("deduction_months")
  monthlyDeduction  Decimal  @map("monthly_deduction") @db.Decimal(12,2)
  remainingAmount   Decimal  @map("remaining_amount") @db.Decimal(12,2)
  disbursedAt       DateTime? @map("disbursed_at")
  status            FestivalAdvanceStatus @default(PENDING)
  approvedBy        String?  @map("approved_by") @db.Uuid
  approvedAt        DateTime? @map("approved_at")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee          Employee     @relation("advance_employee", fields: [employeeId], references: [id], onDelete: Cascade)
  approver          Employee?    @relation("advance_approver", fields: [approvedBy], references: [id])

  @@unique([orgId, employeeId, festivalName, fiscalYear])
  @@index([orgId, fiscalYear])
  @@map("festival_advances")
  @@schema("payroll")
}

enum FestivalAdvanceStatus {
  PENDING
  APPROVED
  DISBURSED
  COMPLETED
  REJECTED
  @@schema("payroll")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPENSATION — Pay Grades, Salary Revisions, Benefits
// ─────────────────────────────────────────────────────────────────────────────

model PayGrade {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  name          String
  level         Int      @default(0)
  minSalary     Decimal  @map("min_salary") @db.Decimal(12,2)
  maxSalary     Decimal  @map("max_salary") @db.Decimal(12,2)
  currency      String   @default("NPR")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@map("pay_grades")
  @@schema("payroll")
}

model SalaryRevision {
  id                String   @id @default(uuid()) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  employeeId        String   @map("employee_id") @db.Uuid
  previousGross     Decimal  @map("previous_gross") @db.Decimal(12,2)
  newGross          Decimal  @map("new_gross") @db.Decimal(12,2)
  previousBasic     Decimal  @map("previous_basic") @db.Decimal(12,2)
  newBasic          Decimal  @map("new_basic") @db.Decimal(12,2)
  revisionType      String   @map("revision_type")
  reason            String?
  effectiveFrom     DateTime @map("effective_from") @db.Date
  status            ApprovalStatus @default(PENDING)
  approvedBy        String?  @map("approved_by") @db.Uuid
  approvedAt        DateTime? @map("approved_at")
  createdAt         DateTime @default(now()) @map("created_at")

  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee          Employee     @relation("revision_employee", fields: [employeeId], references: [id], onDelete: Cascade)
  approver          Employee?    @relation("revision_approver", fields: [approvedBy], references: [id])

  @@index([orgId, employeeId])
  @@map("salary_revisions")
  @@schema("payroll")
}

model BenefitPlan {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  name            String
  category        String
  description     String?
  amount          Decimal? @db.Decimal(12,2)
  isPercentage    Boolean  @default(false) @map("is_percentage")
  percentageOf    String?  @map("percentage_of")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@map("benefit_plans")
  @@schema("payroll")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  @@schema("payroll")
}
