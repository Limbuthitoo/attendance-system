// ─────────────────────────────────────────────────────────────────────────────
// RECRUITMENT — Job Postings, Applicants, Interviews
// ─────────────────────────────────────────────────────────────────────────────

model JobPosting {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  title            String
  department       String?
  designation      String?
  description      String?  @db.Text
  requirements     String?  @db.Text
  location         String?
  employmentType   String   @default("full_time") @map("employment_type")
  salaryMin        Decimal? @map("salary_min") @db.Decimal(12,2)
  salaryMax        Decimal? @map("salary_max") @db.Decimal(12,2)
  vacancies        Int      @default(1)
  status           JobPostingStatus @default(DRAFT)
  publishedAt      DateTime? @map("published_at")
  closingDate      DateTime? @map("closing_date") @db.Date
  createdBy        String   @map("created_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator          Employee     @relation("posting_creator", fields: [createdBy], references: [id])
  applicants       Applicant[]

  @@index([orgId, status])
  @@map("job_postings")
  @@schema("hrm")
}

enum JobPostingStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  FILLED
  CANCELLED
  @@schema("hrm")
}

model Applicant {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  jobPostingId     String   @map("job_posting_id") @db.Uuid
  name             String
  email            String
  phone            String?
  resumeUrl        String?  @map("resume_url")
  coverLetter      String?  @map("cover_letter") @db.Text
  source           String?
  currentCompany   String?  @map("current_company")
  experience       String?
  expectedSalary   Decimal? @map("expected_salary") @db.Decimal(12,2)
  status           ApplicantStatus @default(APPLIED)
  rating           Int?
  notes            String?  @db.Text
  rejectionReason  String?  @map("rejection_reason")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobPosting       JobPosting   @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  interviews       Interview[]

  @@index([orgId, status])
  @@index([jobPostingId])
  @@map("applicants")
  @@schema("hrm")
}

enum ApplicantStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFERED
  OFFER_ACCEPTED
  HIRED
  REJECTED
  WITHDRAWN
  @@schema("hrm")
}

model Interview {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  applicantId      String   @map("applicant_id") @db.Uuid
  interviewerId    String   @map("interviewer_id") @db.Uuid
  scheduledAt      DateTime @map("scheduled_at")
  duration         Int      @default(60)
  type             String   @default("in_person")
  location         String?
  meetingLink      String?  @map("meeting_link")
  status           InterviewStatus @default(SCHEDULED)
  rating           Int?
  feedback         String?  @db.Text
  recommendation   String?
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicant        Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  interviewer      Employee     @relation("interviewer", fields: [interviewerId], references: [id])

  @@index([orgId, scheduledAt])
  @@index([applicantId])
  @@map("interviews")
  @@schema("hrm")
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  @@schema("hrm")
}

// ─────────────────────────────────────────────────────────────────────────────
// ONBOARDING — Templates, Tasks, Checklists
// ─────────────────────────────────────────────────────────────────────────────

model OnboardingTemplate {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  name             String
  department       String?
  description      String?
  tasks            Json     @default("[]")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@map("onboarding_templates")
  @@schema("hrm")
}

model OnboardingTask {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  employeeId       String   @map("employee_id") @db.Uuid
  title            String
  description      String?
  category         String   @default("general")
  assignedTo       String?  @map("assigned_to") @db.Uuid
  dueDate          DateTime? @map("due_date") @db.Date
  completedAt      DateTime? @map("completed_at")
  status           OnboardingTaskStatus @default(PENDING)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // employeeId = the new hire being onboarded
  // assignedTo = HR/manager responsible for completing the task
  assignee         Employee?    @relation("onboarding_assignee", fields: [assignedTo], references: [id])

  @@index([orgId, employeeId])
  @@map("onboarding_tasks")
  @@schema("hrm")
}

enum OnboardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  @@schema("hrm")
}

// ─────────────────────────────────────────────────────────────────────────────
// SEPARATION — Resignation, Exit, Clearance, Final Settlement
// ─────────────────────────────────────────────────────────────────────────────

model Separation {
  id                  String   @id @default(uuid()) @db.Uuid
  orgId               String   @map("org_id") @db.Uuid
  employeeId          String   @map("employee_id") @db.Uuid
  type                SeparationType
  reason              String?  @db.Text
  resignationDate     DateTime? @map("resignation_date") @db.Date
  lastWorkingDate     DateTime? @map("last_working_date") @db.Date
  noticePeriodDays    Int      @default(30) @map("notice_period_days")
  noticePeriodServed  Int      @default(0) @map("notice_period_served")
  exitInterviewDone   Boolean  @default(false) @map("exit_interview_done")
  exitInterviewNotes  String?  @map("exit_interview_notes") @db.Text
  status              SeparationStatus @default(INITIATED)
  processedBy         String?  @map("processed_by") @db.Uuid
  processedAt         DateTime? @map("processed_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  employee            Employee     @relation("separation_employee", fields: [employeeId], references: [id], onDelete: Cascade)
  processor           Employee?    @relation("separation_processor", fields: [processedBy], references: [id])
  clearanceItems      ClearanceItem[]
  finalSettlement     FinalSettlement?

  @@unique([orgId, employeeId, type])
  @@index([orgId, status])
  @@map("separations")
  @@schema("hrm")
}

enum SeparationType {
  RESIGNATION
  TERMINATION
  RETIREMENT
  CONTRACT_END
  MUTUAL_SEPARATION
  @@schema("hrm")
}

enum SeparationStatus {
  INITIATED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  CLEARANCE_COMPLETED
  SETTLEMENT_PENDING
  COMPLETED
  CANCELLED
  @@schema("hrm")
}

model ClearanceItem {
  id               String   @id @default(uuid()) @db.Uuid
  separationId     String   @map("separation_id") @db.Uuid
  department       String
  itemName         String   @map("item_name")
  description      String?
  status           ClearanceStatus @default(PENDING)
  approvedBy       String?  @map("approved_by") @db.Uuid
  approvedAt       DateTime? @map("approved_at")
  remarks          String?
  createdAt        DateTime @default(now()) @map("created_at")

  separation       Separation @relation(fields: [separationId], references: [id], onDelete: Cascade)
  approver         Employee?  @relation("clearance_approver", fields: [approvedBy], references: [id])

  @@index([separationId])
  @@map("clearance_items")
  @@schema("hrm")
}

enum ClearanceStatus {
  PENDING
  CLEARED
  NOT_APPLICABLE
  BLOCKED
  @@schema("hrm")
}

model FinalSettlement {
  id                  String   @id @default(uuid()) @db.Uuid
  separationId        String   @unique @map("separation_id") @db.Uuid
  basicDues           Decimal  @default(0) @map("basic_dues") @db.Decimal(12,2)
  leaveEncashment     Decimal  @default(0) @map("leave_encashment") @db.Decimal(12,2)
  gratuity            Decimal  @default(0) @db.Decimal(12,2)
  bonus               Decimal  @default(0) @db.Decimal(12,2)
  noticePeriodRecovery Decimal @default(0) @map("notice_period_recovery") @db.Decimal(12,2)
  advanceRecovery     Decimal  @default(0) @map("advance_recovery") @db.Decimal(12,2)
  otherDeductions     Decimal  @default(0) @map("other_deductions") @db.Decimal(12,2)
  otherEarnings       Decimal  @default(0) @map("other_earnings") @db.Decimal(12,2)
  tds                 Decimal  @default(0) @db.Decimal(12,2)
  netPayable          Decimal  @default(0) @map("net_payable") @db.Decimal(12,2)
  breakdown           Json     @default("{}") @map("breakdown")
  status              SettlementStatus @default(DRAFT)
  paidAt              DateTime? @map("paid_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  separation          Separation @relation(fields: [separationId], references: [id], onDelete: Cascade)

  @@map("final_settlements")
  @@schema("hrm")
}

enum SettlementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  @@schema("hrm")
}
