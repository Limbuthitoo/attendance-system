{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ANDROID_HOME": "/opt/homebrew/share/android-commandlinetools"
      }
    },
    "local": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ANDROID_HOME": "/opt/homebrew/share/android-commandlinetools"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "ANDROID_HOME": "/opt/homebrew/share/android-commandlinetools"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
