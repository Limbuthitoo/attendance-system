{
  "expo": {
    "name": "Archisys Attendance",
    "slug": "archisys-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563eb",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.archisys.attendance"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "com.archisys.attendance"
    },
    "extra": {
      "apiUrl": "http://192.168.1.3:3001/api"
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset"
    ]
  }
}
