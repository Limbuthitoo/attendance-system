{
  "expo": {
    "name": "Archisys Attendance",
    "slug": "archisys-attendance",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563eb",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.archisys.attendance"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.archisys.attendance"
    },
    "extra": {
      "apiUrl": "https://hr.bijaysubbalimbu.com.np/api",
      "eas": {
        "projectId": "aacb0d69-5f22-45db-8edb-22fe97a92a02"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2563eb"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": false,
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ],
      "./plugins/withAbiFilter",
      "@react-native-community/datetimepicker"
    ]
  }
}
