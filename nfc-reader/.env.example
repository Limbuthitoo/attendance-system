# Archisys Attendance backend URL
API_URL=http://localhost:3001
# Device serial — from platform admin device registration
DEVICE_SERIAL=FP-2024-001
# Per-device API key — shown once when registering the device in platform admin
NFC_API_KEY=dev_xxxxxxxxxxxxxxxx
# Unique ID for this reader (display name in logs)
DEVICE_ID=front-desk-01
# Minimum seconds between taps from the same card (debounce)
DEBOUNCE_SECONDS=5
# Retry queue: max items to buffer when backend is unreachable
RETRY_QUEUE_MAX=100
# How often to poll backend for pending write jobs (seconds)
WRITE_POLL_SECONDS=3
# Cooldown after a successful check-in/out before accepting the same card again (seconds)
ACTION_COOLDOWN_SECONDS=30
